# Get a free key at https://aistudio.google.com/apikey
GEMINI_API_KEY=

# Get a bot token from @BotFather on Telegram
TELEGRAM_BOT_TOKEN=

# Your chat ID (use @userinfobot to find it, or your group/channel id with -100 prefix)
TELEGRAM_CHAT_ID=

# Brevo (Sendinblue) — get an API v3 key at https://app.brevo.com/settings/keys/api
BREVO_API_KEY=

# Comma-separated list of recipient emails
EMAIL_TO=

# Optional sender override (default: notirelevanteperu@noreply.brevo.com)
EMAIL_FROM=
EMAIL_FROM_NAME=NotiRelevantePerú

# Public URL where the site lives (used in Telegram captions and email)
SITE_BASE_URL=https://alduere.github.io/notirelevanteperu
