---
import type { NormaResumida } from "../lib/types";
import NormaItem from "./NormaItem.astro";

interface Props {
  sector: string;
  norms: NormaResumida[];
  highlight?: boolean;
}

const { sector, norms } = Astro.props;
const sectorTitle = sector.replace(/_/g, " ");
const altoCount = norms.filter((n) => n.impacto === "alto").length;
const medioCount = norms.filter((n) => n.impacto === "medio").length;
const bajoCount = norms.filter((n) => n.impacto === "bajo").length;
---

<article class="mb-8" data-sector-card>
  <header class="flex items-baseline justify-between gap-3 pb-2 mb-1 border-b border-edge">
    <h2 class="font-display font-bold text-lg capitalize text-txt">
      {sectorTitle}
      <span class="text-txt-dim font-sans text-sm font-normal ml-2">({norms.length})</span>
    </h2>
    <div class="flex gap-2">
      {altoCount > 0 && (
        <span class="inline-flex items-center gap-1 text-xs font-medium text-impact-alto">
          <span class="w-2 h-2 rounded-full bg-impact-alto inline-block"></span>
          {altoCount}
        </span>
      )}
      {medioCount > 0 && (
        <span class="inline-flex items-center gap-1 text-xs font-medium text-impact-medio">
          <span class="w-2 h-2 rounded-full bg-impact-medio inline-block"></span>
          {medioCount}
        </span>
      )}
      {bajoCount > 0 && (
        <span class="inline-flex items-center gap-1 text-xs font-medium text-impact-bajo">
          <span class="w-2 h-2 rounded-full bg-impact-bajo inline-block"></span>
          {bajoCount}
        </span>
      )}
    </div>
  </header>

  <div class="space-y-0">
    {norms.map((n) => (
      <NormaItem norma={n} compact />
    ))}
  </div>
</article>
