---
import type { NormaResumida } from "../lib/types";

interface Props {
  norma: NormaResumida;
  compact?: boolean;
  dark?: boolean;
}

const { norma, compact = false } = Astro.props;
const meta = `${norma.tipo_corto}${norma.numero ? ` ${norma.numero}` : ""}`;
const base = import.meta.env.BASE_URL.replace(/\/$/, "");
const sectoresAttr = (norma.sectores || []).join(",");
---

<a
  href={`${base}/n/${norma.id}`}
  class="ruled-item block"
  data-norma
  data-tipo={norma.tipo_corto}
  data-impacto={norma.impacto}
  data-sectores={sectoresAttr}
>
  <div class="flex items-start gap-2 mb-1">
    <span class={`impact-pill ${norma.impacto} shrink-0`}>{norma.impacto}</span>
    <div class="text-xs uppercase tracking-wider text-txt-tertiary truncate font-sans">
      {meta} &middot; {norma.entidad_emisora}
    </div>
  </div>
  <div class={`font-display font-bold text-sm leading-snug text-txt hover:text-txt-secondary ${compact ? "line-clamp-2" : ""}`}>
    {norma.titulo_oficial}
  </div>
  {!compact && norma.resumen_ejecutivo && (
    <p class="text-xs leading-relaxed mt-1.5 text-txt-secondary line-clamp-3 font-sans">
      {norma.resumen_ejecutivo}
    </p>
  )}
  {compact && norma.sumilla && (
    <p class="text-xs leading-snug mt-1 text-txt-tertiary line-clamp-2 italic font-sans">
      {norma.sumilla}
    </p>
  )}
</a>
