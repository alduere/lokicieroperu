---
import type { NormaResumida } from "../lib/types";

interface Props {
  norma: NormaResumida;
  compact?: boolean;
  dark?: boolean;
}

const { norma, compact = false, dark = false } = Astro.props;
const meta = `${norma.tipo_corto}${norma.numero ? ` ${norma.numero}` : ""}`;
const base = import.meta.env.BASE_URL.replace(/\/$/, "");
const sectoresAttr = (norma.sectores || []).join(",");
---

<div
  class={`pb-3 ${dark ? "border-b border-white/10" : "border-b border-ink-100"} last:border-0 last:pb-0`}
  data-norma
  data-tipo={norma.tipo_corto}
  data-impacto={norma.impacto}
  data-sectores={sectoresAttr}
>
  <div class="flex items-start gap-2 mb-1">
    <span class={`impact-pill ${norma.impacto} shrink-0 ${dark ? "!bg-white/10 !text-white" : ""}`}>{norma.impacto}</span>
    <div class={`text-[10px] uppercase tracking-wider font-mono ${dark ? "text-white/60" : "text-ink-500"} truncate`}>
      {meta} · {norma.entidad_emisora}
    </div>
  </div>
  <a
    href={`${base}/n/${norma.id}`}
    class={`block text-sm font-semibold leading-snug ${dark ? "text-white hover:text-white/80" : "text-ink-900 hover:text-ink-700"} ${compact ? "line-clamp-2" : ""}`}
  >
    {norma.titulo_oficial}
  </a>
  {!compact && norma.resumen_ejecutivo && (
    <p class={`text-xs leading-relaxed mt-1.5 ${dark ? "text-white/80" : "text-ink-600"} line-clamp-3`}>
      {norma.resumen_ejecutivo}
    </p>
  )}
  {compact && (
    <p class={`text-xs leading-snug mt-1 ${dark ? "text-white/70" : "text-ink-500"} line-clamp-2 italic`}>
      {norma.sumilla}
    </p>
  )}
</div>
