---
import type { DiaProcesado } from "../lib/types";
import { formatFechaEs } from "../lib/data";

interface Props {
  dia: DiaProcesado;
}

const { dia } = Astro.props;
const fechaEs = formatFechaEs(dia.fecha);
const base = import.meta.env.BASE_URL.replace(/\/$/, "");
---

<section class="pb-6 mb-6 border-b border-edge">
  <div class="grid grid-cols-1 lg:grid-cols-3 gap-8 items-center">
    <div class="lg:col-span-2">
      <div class="text-xs uppercase tracking-widest text-txt-dim mb-2 font-sans">Edici&oacute;n del</div>
      <h1 class="font-display font-extrabold text-3xl sm:text-5xl tracking-tightest leading-none text-txt">{fechaEs}</h1>
      <div class="mt-6 flex items-end gap-2">
        <div class="font-display font-extrabold text-7xl sm:text-8xl tracking-tightest leading-none text-txt">{dia.stats.total_normas}</div>
        <div class="text-txt-dim pb-3 text-sm uppercase tracking-widest font-sans">normas legales publicadas</div>
      </div>

      <div class="mt-6 flex flex-wrap gap-3">
        <a href={`${base}/pdfs/${dia.fecha}.pdf`} class="inline-flex items-center gap-2 px-4 py-2 rounded-lg bg-loki-elevated border border-edge text-txt text-sm font-medium hover:border-edge-hover transition-colors">
          <span>&#128206;</span>
          <span>Descargar PDF del d&iacute;a</span>
        </a>
      </div>
    </div>

    <div class="grid grid-cols-3 gap-3">
      <div class="border border-edge rounded-lg p-4 text-center bg-loki-surface">
        <div class="text-impact-alto font-display font-extrabold text-4xl leading-none">{dia.stats.alto}</div>
        <div class="text-xs uppercase tracking-widest mt-2 text-txt-dim">Alto</div>
      </div>
      <div class="border border-edge rounded-lg p-4 text-center bg-loki-surface">
        <div class="text-impact-medio font-display font-extrabold text-4xl leading-none">{dia.stats.medio}</div>
        <div class="text-xs uppercase tracking-widest mt-2 text-txt-dim">Medio</div>
      </div>
      <div class="border border-edge rounded-lg p-4 text-center bg-loki-surface">
        <div class="text-impact-bajo font-display font-extrabold text-4xl leading-none">{dia.stats.bajo}</div>
        <div class="text-xs uppercase tracking-widest mt-2 text-txt-dim">Bajo</div>
      </div>
    </div>
  </div>
</section>
