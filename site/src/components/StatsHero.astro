---
import type { DiaProcesado } from "../lib/types";
import { formatFechaEs } from "../lib/data";

interface Props {
  dia: DiaProcesado;
}

const { dia } = Astro.props;
const fechaEs = formatFechaEs(dia.fecha);
const base = import.meta.env.BASE_URL.replace(/\/$/, "");
---

<section class="glass p-6 sm:p-8 mb-6">
  <div class="grid grid-cols-1 lg:grid-cols-3 gap-8 items-center">
    <div class="lg:col-span-2">
      <div class="text-xs uppercase tracking-widest text-ink-500 mb-2">Edición del</div>
      <h1 class="text-3xl sm:text-5xl font-bold tracking-tightest leading-none">{fechaEs}</h1>
      <div class="mt-6 flex items-end gap-2">
        <div class="text-7xl sm:text-8xl font-extrabold tracking-tightest leading-none">{dia.stats.total_normas}</div>
        <div class="text-ink-500 pb-3 text-sm uppercase tracking-widest">normas legales publicadas</div>
      </div>

      <div class="mt-6 flex flex-wrap gap-3">
        <a href={`${base}/pdfs/${dia.fecha}.pdf`} class="inline-flex items-center gap-2 px-4 py-2 rounded-lg bg-ink-900 text-white text-sm font-medium hover:bg-ink-700 transition-colors">
          <span>📎</span>
          <span>Descargar PDF del día</span>
        </a>
      </div>
    </div>

    <div class="grid grid-cols-3 gap-3">
      <div class="rounded-xl bg-impact-alto p-4 text-white">
        <div class="text-4xl font-extrabold leading-none">{dia.stats.alto}</div>
        <div class="text-xs uppercase tracking-widest mt-2 opacity-90">Alto impacto</div>
      </div>
      <div class="rounded-xl bg-impact-medio p-4 text-white">
        <div class="text-4xl font-extrabold leading-none">{dia.stats.medio}</div>
        <div class="text-xs uppercase tracking-widest mt-2 opacity-90">Medio</div>
      </div>
      <div class="rounded-xl bg-impact-bajo p-4 text-white">
        <div class="text-4xl font-extrabold leading-none">{dia.stats.bajo}</div>
        <div class="text-xs uppercase tracking-widest mt-2 opacity-90">Bajo</div>
      </div>
    </div>
  </div>
</section>
