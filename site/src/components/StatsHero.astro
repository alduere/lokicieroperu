---
import type { DiaProcesado } from "../lib/types";
import { formatFechaEs } from "../lib/data";

interface Props {
  dia: DiaProcesado;
}

const { dia } = Astro.props;
const fechaEs = formatFechaEs(dia.fecha);
const base = import.meta.env.BASE_URL.replace(/\/$/, "");
---

<section class="pb-6 mb-6 border-b border-ink-rule">
  <div class="grid grid-cols-1 lg:grid-cols-3 gap-8 items-center">
    <div class="lg:col-span-2">
      <div class="text-xs uppercase tracking-widest text-ink-sepia mb-2 font-sans">Edici&oacute;n del</div>
      <h1 class="font-display font-black text-3xl sm:text-5xl tracking-tightest leading-none text-ink">{fechaEs}</h1>
      <div class="mt-6 flex items-end gap-2">
        <div class="font-display font-black text-7xl sm:text-8xl tracking-tightest leading-none text-ink">{dia.stats.total_normas}</div>
        <div class="text-ink-sepia pb-3 text-sm uppercase tracking-widest font-sans">normas legales publicadas</div>
      </div>

      <div class="mt-6 flex flex-wrap gap-3">
        <a href={`${base}/pdfs/${dia.fecha}.pdf`} class="inline-flex items-center gap-2 px-4 py-2 rounded-lg bg-ink text-parchment-light text-sm font-medium hover:opacity-90 transition-opacity">
          <span>&#128206;</span>
          <span>Descargar PDF del d&iacute;a</span>
        </a>
      </div>
    </div>

    <div class="grid grid-cols-3 gap-3">
      <div class="border border-ink-rule rounded-lg p-4 text-center">
        <div class="text-impact-alto font-display font-black text-4xl leading-none">{dia.stats.alto}</div>
        <div class="text-xs uppercase tracking-widest mt-2 text-ink-sepia">Alto impacto</div>
      </div>
      <div class="border border-ink-rule rounded-lg p-4 text-center">
        <div class="text-impact-medio font-display font-black text-4xl leading-none">{dia.stats.medio}</div>
        <div class="text-xs uppercase tracking-widest mt-2 text-ink-sepia">Medio</div>
      </div>
      <div class="border border-ink-rule rounded-lg p-4 text-center">
        <div class="text-impact-bajo font-display font-black text-4xl leading-none">{dia.stats.bajo}</div>
        <div class="text-xs uppercase tracking-widest mt-2 text-ink-sepia">Bajo</div>
      </div>
    </div>
  </div>
</section>
