---
interface Props {
  slug: string;
  nombre: string;
  subtitulo: string;
  total: number;
  label: string;
  categorias: { nombre: string; count: number; color: string }[];
  updatedAt: string;
  featured?: boolean;
}

const { slug, nombre, subtitulo, total, label, categorias, updatedAt, featured = false } = Astro.props;
const base = import.meta.env.BASE_URL.replace(/\/$/, "");
const isEmpty = total === 0;

const updatedDate = new Date(updatedAt);
const timeStr = updatedDate.toLocaleTimeString("es-PE", {
  hour: "2-digit",
  minute: "2-digit",
  timeZone: "America/Lima",
});
---

<a
  href={`${base}/${slug}/`}
  class:list={[
    "loki-card block p-6 transition-all duration-200 hover:scale-[1.02] hover:shadow-lg group",
    { "col-span-2": featured },
    { "opacity-60": isEmpty },
  ]}
>
  <div class="flex items-start justify-between gap-4 mb-4">
    <div>
      <h3 class="text-lg font-bold tracking-tightest text-txt group-hover:text-txt transition-colors">
        {nombre}
      </h3>
      <p class="text-xs text-txt-dim mt-0.5">{subtitulo}</p>
    </div>
  </div>

  <div class="flex items-end gap-2 mb-4">
    <div class:list={[
      "text-5xl font-extrabold tracking-tightest leading-none",
      isEmpty ? "text-txt-dim" : "text-txt",
    ]}>
      {total}
    </div>
    <div class="text-txt-dim pb-1 text-sm uppercase tracking-widest">{label}</div>
  </div>

  {categorias.length > 0 && (
    <div class="flex flex-wrap gap-1.5 mb-4">
      {categorias.map((cat) => (
        <span class={`inline-flex items-center gap-1 px-2 py-0.5 rounded-md text-xs font-semibold text-white ${cat.color}`}>
          {cat.nombre} <span class="opacity-80">{cat.count}</span>
        </span>
      ))}
    </div>
  )}

  <div class="text-xs text-txt-dim mt-auto">
    Actualizado {timeStr}
  </div>
</a>
