---
import type { DiaProcesado, NormaResumida } from "../lib/types";
import SectorCard from "./SectorCard.astro";

interface Props {
  dia: DiaProcesado;
}

const { dia } = Astro.props;

// Group norms by primary sector
const groups = new Map<string, NormaResumida[]>();
for (const n of dia.normas) {
  const primary = n.sectores[0] || "administracion_publica";
  if (!groups.has(primary)) groups.set(primary, []);
  groups.get(primary)!.push(n);
}

// Sort sectors by total count desc
const sortedGroups = [...groups.entries()].sort((a, b) => b[1].length - a[1].length);

// Sort norms within each sector: alto first, then medio, then bajo
const ORDER = { alto: 0, medio: 1, bajo: 2 };
for (const [, norms] of sortedGroups) {
  norms.sort((a, b) => ORDER[a.impacto] - ORDER[b.impacto]);
}

// Bento sizing: top 2 sectors get larger cards, next ones smaller.
function gridSpan(idx: number, count: number): string {
  if (idx === 0) return "md:col-span-2 md:row-span-2";
  if (idx === 1 && count > 4) return "md:col-span-1 md:row-span-2";
  return "md:col-span-1 md:row-span-1";
}
---

<section class="grid grid-cols-1 md:grid-cols-3 lg:grid-cols-4 auto-rows-[minmax(220px,auto)] gap-4">
  {sortedGroups.map(([sector, norms], idx) => (
    <div class={gridSpan(idx, norms.length)}>
      <SectorCard sector={sector} norms={norms} highlight={idx === 0} />
    </div>
  ))}
</section>

{dia.documentos.length > 0 && (
  <section class="mt-10">
    <h2 class="text-xs uppercase tracking-widest text-ink-500 mb-3">Otras secciones del día</h2>
    <div class="glass p-6">
      <ul class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-3 text-sm">
        {dia.documentos.map((d) => (
          <li class="flex items-center justify-between gap-3 py-2 border-b border-ink-100 last:border-0">
            <div>
              <div class="font-semibold text-ink-900 text-xs uppercase tracking-wider">{d.seccion.replace(/_/g, " ")}</div>
              <div class="text-ink-600">Edición {d.edicion}</div>
            </div>
            <a href={d.descarga_url} class="text-ink-500 hover:text-ink-900 text-xs">PDF →</a>
          </li>
        ))}
      </ul>
    </div>
  </section>
)}
