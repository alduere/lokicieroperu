---
import type { NormaResumida } from "../lib/types";

interface Props {
  normas: NormaResumida[];
}

const { normas } = Astro.props;

// Compute counts per tipo and per impacto
const tipoCounts = new Map<string, number>();
const impactoCounts = new Map<string, number>();
const sectorCounts = new Map<string, number>();
for (const n of normas) {
  tipoCounts.set(n.tipo_corto, (tipoCounts.get(n.tipo_corto) || 0) + 1);
  impactoCounts.set(n.impacto, (impactoCounts.get(n.impacto) || 0) + 1);
  for (const s of n.sectores) sectorCounts.set(s, (sectorCounts.get(s) || 0) + 1);
}
const tipos = [...tipoCounts.entries()].sort((a, b) => b[1] - a[1]);
const sectores = [...sectorCounts.entries()].sort((a, b) => b[1] - a[1]).slice(0, 12);

const TIPO_LABELS: Record<string, string> = {
  DS: "Decreto Supremo",
  DU: "Decreto de Urgencia",
  DL: "Decreto Legislativo",
  LEY: "Ley",
  RM: "R. Ministerial",
  RVM: "R. Viceministerial",
  RD: "R. Directoral",
  RS: "R. Superintendencia",
  RJ: "R. Jefatural",
  RA: "R. Administrativa",
  RPRE: "R. Presidencia",
  RCD: "R. Consejo Directivo",
  RSU: "R. Suprema",
  RES: "Resoluci\u00f3n",
  OR: "Ordenanza Regional",
  OM: "Ordenanza Municipal",
  ORD: "Ordenanza",
  AC: "Acuerdo de Consejo",
  ACU: "Acuerdo",
  CIRC: "Circular",
  DIR: "Directiva",
  FE: "Fe de Erratas",
  REG: "Reglamento",
  PROT: "Protocolo",
  OTRO: "Otro",
};
---

<div class="py-4 mb-6 border-b border-ink-rule" id="filters">
  <div class="flex items-center gap-2 flex-wrap">
    <span class="text-xs font-sans font-semibold text-ink-sepia uppercase tracking-widest mr-2">Filtrar:</span>

    <div class="flex flex-wrap gap-1.5">
      <button
        class="filter-chip filter-impacto active text-xs px-3 py-1.5 rounded-md bg-ink text-parchment-light font-semibold font-sans"
        data-filter-type="impacto"
        data-filter-value="all"
      >Todos</button>
      <button
        class="filter-chip filter-impacto text-xs px-3 py-1.5 rounded-md border border-ink-rule text-impact-alto font-semibold font-sans hover:bg-ink hover:text-parchment-light transition-colors"
        data-filter-type="impacto"
        data-filter-value="alto"
      >Alto ({impactoCounts.get("alto") || 0})</button>
      <button
        class="filter-chip filter-impacto text-xs px-3 py-1.5 rounded-md border border-ink-rule text-impact-medio font-semibold font-sans hover:bg-ink hover:text-parchment-light transition-colors"
        data-filter-type="impacto"
        data-filter-value="medio"
      >Medio ({impactoCounts.get("medio") || 0})</button>
      <button
        class="filter-chip filter-impacto text-xs px-3 py-1.5 rounded-md border border-ink-rule text-impact-bajo font-semibold font-sans hover:bg-ink hover:text-parchment-light transition-colors"
        data-filter-type="impacto"
        data-filter-value="bajo"
      >Bajo ({impactoCounts.get("bajo") || 0})</button>
    </div>
  </div>

  <details class="mt-3 text-xs">
    <summary class="cursor-pointer text-ink-sepia font-semibold uppercase tracking-widest hover:text-ink font-sans">
      Filtrar por tipo de norma ({tipos.length})
    </summary>
    <div class="mt-2 flex flex-wrap gap-1.5">
      <button class="filter-chip filter-tipo active text-xs px-2.5 py-1 rounded-md bg-ink text-parchment-light font-semibold font-sans" data-filter-type="tipo" data-filter-value="all">Todos</button>
      {tipos.map(([code, count]) => (
        <button
          class="filter-chip filter-tipo text-xs px-2.5 py-1 rounded-md border border-ink-rule text-ink-sepia hover:bg-ink hover:text-parchment-light transition-colors font-mono"
          data-filter-type="tipo"
          data-filter-value={code}
          title={TIPO_LABELS[code] || code}
        >{code} ({count})</button>
      ))}
    </div>
  </details>

  {sectores.length > 0 && (
    <details class="mt-3 text-xs">
      <summary class="cursor-pointer text-ink-sepia font-semibold uppercase tracking-widest hover:text-ink font-sans">
        Filtrar por sector ({sectores.length})
      </summary>
      <div class="mt-2 flex flex-wrap gap-1.5">
        <button class="filter-chip filter-sector active text-xs px-2.5 py-1 rounded-md bg-ink text-parchment-light font-semibold font-sans" data-filter-type="sector" data-filter-value="all">Todos</button>
        {sectores.map(([sector, count]) => (
          <button
            class="filter-chip filter-sector text-xs px-2.5 py-1 rounded-md border border-ink-rule text-ink-sepia hover:bg-ink hover:text-parchment-light transition-colors font-sans"
            data-filter-type="sector"
            data-filter-value={sector}
          >{sector.replace(/_/g, " ")} ({count})</button>
        ))}
      </div>
    </details>
  )}
</div>

<script is:inline>
  (function () {
    const state = { impacto: "all", tipo: "all", sector: "all" };

    function applyFilters() {
      const cards = document.querySelectorAll("[data-norma]");
      let hidden = 0;
      cards.forEach((el) => {
        const tipo = el.getAttribute("data-tipo") || "";
        const impacto = el.getAttribute("data-impacto") || "";
        const sectores = (el.getAttribute("data-sectores") || "").split(",");
        const matchImpacto = state.impacto === "all" || impacto === state.impacto;
        const matchTipo = state.tipo === "all" || tipo === state.tipo;
        const matchSector = state.sector === "all" || sectores.includes(state.sector);
        const visible = matchImpacto && matchTipo && matchSector;
        el.style.display = visible ? "" : "none";
        if (!visible) hidden++;
      });

      // Hide sector cards that have no visible norms left
      document.querySelectorAll("[data-sector-card]").forEach((card) => {
        const visible = card.querySelectorAll('[data-norma]:not([style*="display: none"])');
        card.style.display = visible.length > 0 ? "" : "none";
      });

      const counter = document.getElementById("filter-count");
      if (counter) {
        const total = cards.length;
        counter.textContent = hidden > 0 ? "Mostrando " + (total - hidden) + " de " + total : total + " normas";
      }
    }

    document.querySelectorAll(".filter-chip").forEach((btn) => {
      btn.addEventListener("click", () => {
        const type = btn.getAttribute("data-filter-type");
        const value = btn.getAttribute("data-filter-value");
        if (!type || !value) return;
        state[type] = value;
        document.querySelectorAll(".filter-" + type).forEach((b) => {
          b.classList.toggle("active", b.getAttribute("data-filter-value") === value);
          if (b.classList.contains("active")) {
            b.classList.add("bg-ink", "text-parchment-light");
            b.classList.remove("border", "border-ink-rule", "text-ink-sepia", "text-impact-alto", "text-impact-medio", "text-impact-bajo");
          } else if (type === "impacto") {
            var v = b.getAttribute("data-filter-value");
            b.classList.remove("bg-ink", "text-parchment-light");
            b.classList.add("border", "border-ink-rule");
            if (v === "alto") b.classList.add("text-impact-alto");
            else if (v === "medio") b.classList.add("text-impact-medio");
            else if (v === "bajo") b.classList.add("text-impact-bajo");
          } else {
            b.classList.remove("bg-ink", "text-parchment-light");
            b.classList.add("border", "border-ink-rule", "text-ink-sepia");
          }
        });
        applyFilters();
      });
    });
  })();
</script>
