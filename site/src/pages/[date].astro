---
import Base from "../layouts/Base.astro";
import StatsHero from "../components/StatsHero.astro";
import BentoGrid from "../components/BentoGrid.astro";
import FilterBar from "../components/FilterBar.astro";
import { sortedDates, getDay } from "../lib/data";

export async function getStaticPaths() {
  return sortedDates
    .filter((date) => date && /^\d{4}-\d{2}-\d{2}$/.test(date))
    .map((date) => ({
      params: { date },
      props: { dia: getDay(date) },
    }));
}

const { dia } = Astro.props;
---

<Base title={`Loki-ciero Perú · ${dia.fecha}`}>
  <StatsHero dia={dia} />
  <FilterBar normas={dia.normas} />
  <BentoGrid dia={dia} />
</Base>
