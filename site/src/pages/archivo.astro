---
import Base from "../layouts/Base.astro";
import { sortedDates, getDay, formatFechaEs } from "../lib/data";

const base = import.meta.env.BASE_URL.replace(/\/$/, "");
const days = sortedDates.map((d) => ({ date: d, dia: getDay(d)! }));
---

<Base title="Archivo · NotiRelevantePerú">
  <div class="mb-8">
    <h1 class="text-4xl font-bold tracking-tightest">Archivo</h1>
    <p class="text-ink-500 mt-2">Todas las ediciones diarias publicadas</p>
  </div>

  <div class="glass overflow-hidden">
    <table class="w-full text-sm">
      <thead class="bg-ink-50 border-b border-ink-200">
        <tr>
          <th class="text-left px-4 py-3 font-semibold text-ink-700 uppercase text-xs tracking-wider">Fecha</th>
          <th class="text-right px-4 py-3 font-semibold text-ink-700 uppercase text-xs tracking-wider">Total</th>
          <th class="text-right px-4 py-3 font-semibold text-ink-700 uppercase text-xs tracking-wider">Alto</th>
          <th class="text-right px-4 py-3 font-semibold text-ink-700 uppercase text-xs tracking-wider">Medio</th>
          <th class="text-right px-4 py-3 font-semibold text-ink-700 uppercase text-xs tracking-wider">Bajo</th>
          <th class="text-right px-4 py-3 font-semibold text-ink-700 uppercase text-xs tracking-wider">PDF</th>
        </tr>
      </thead>
      <tbody>
        {days.map(({ date, dia }) => (
          <tr class="border-b border-ink-100 hover:bg-ink-50">
            <td class="px-4 py-3">
              <a href={`${base}/${date}`} class="font-semibold text-ink-900 hover:text-ink-700">
                {formatFechaEs(date)}
              </a>
            </td>
            <td class="px-4 py-3 text-right font-mono">{dia.stats.total_normas}</td>
            <td class="px-4 py-3 text-right font-mono text-impact-alto">{dia.stats.alto}</td>
            <td class="px-4 py-3 text-right font-mono text-impact-medio">{dia.stats.medio}</td>
            <td class="px-4 py-3 text-right font-mono text-impact-bajo">{dia.stats.bajo}</td>
            <td class="px-4 py-3 text-right">
              <a href={`${base}/pdfs/${date}.pdf`} class="text-ink-500 hover:text-ink-900 text-xs">↓ PDF</a>
            </td>
          </tr>
        ))}
      </tbody>
    </table>
  </div>
</Base>
