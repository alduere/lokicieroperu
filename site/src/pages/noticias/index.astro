---
import Base from "../../layouts/Base.astro";
import { latestNoticiasDate, getNoticiasDay, formatFechaEs } from "../../lib/data";
import type { PrensaResumida } from "../../lib/types";

const date = latestNoticiasDate();
const dia = date ? getNoticiasDay(date) : null;
const base = import.meta.env.BASE_URL.replace(/\/$/, "");

// Group by source
const bySource: Record<string, PrensaResumida[]> = {};
const byCategory: Record<string, PrensaResumida[]> = {};
if (dia) {
  for (const n of dia.noticias) {
    const src = n.fuente_display || n.fuente;
    if (!bySource[src]) bySource[src] = [];
    bySource[src].push(n);

    const cat = n.categoria || "Otros";
    if (!byCategory[cat]) byCategory[cat] = [];
    byCategory[cat].push(n);
  }
}

const allItems = dia ? dia.noticias : [];
const sources = Object.keys(bySource).sort();
const categories = Object.keys(byCategory).sort();

function categoriaPillClass(cat: string): string {
  const lower = cat.toLowerCase();
  if (lower.includes("econom")) return "bg-[#9a6b1a] text-white";
  if (lower.includes("finanz")) return "bg-[#3a6b3a] text-white";
  if (lower.includes("politi") || lower.includes("polit")) return "bg-[#8b2020] text-white";
  return "bg-loki-elevated text-white";
}
---

<Base title={dia ? `Noticias · ${dia.fecha}` : "Noticias · Loki"} sourceSlug="noticias" sourceName="Noticias">
  <nav class="text-xs text-txt-dim mb-4">
    <a href={`${base}/`} class="hover:text-txt">Inicio</a>
    <span class="mx-1">&rsaquo;</span>
    <span class="text-txt">Noticias</span>
  </nav>

  {dia && allItems.length > 0 ? (
    <>
      <div class="border-b-2 border-edge pb-6 mb-6">
        <div class="text-xs uppercase tracking-widest text-txt-dim mb-1">{formatFechaEs(dia.fecha)}</div>
        <h1 class="font-display text-4xl sm:text-5xl font-extrabold tracking-tightest mb-3">Noticias</h1>
        <div class="flex items-center gap-6 text-sm text-txt-muted">
          <div><span class="font-display text-3xl font-bold text-txt">{allItems.length}</span> articulos</div>
          <div><span class="font-display text-3xl font-bold text-txt">{sources.length}</span> fuentes</div>
        </div>
      </div>

      {/* Filter pills */}
      <div class="flex flex-wrap gap-2 mb-6">
        <button class="noticias-filter active text-xs px-3 py-1.5 rounded-full border border-edge font-semibold transition-all cursor-pointer" data-filter="all">
          Todas ({allItems.length})
        </button>
        {categories.map((cat) => (
          <button class={`noticias-filter text-xs px-3 py-1.5 rounded-full border font-semibold transition-all cursor-pointer ${categoriaPillClass(cat)}`} data-filter={cat}>
            {cat} ({byCategory[cat].length})
          </button>
        ))}
      </div>

      {/* Source filter */}
      <div class="flex flex-wrap gap-2 mb-8">
        {sources.map((src) => (
          <button class="noticias-source-filter text-xs px-3 py-1.5 rounded-full border border-edge text-txt-dim font-semibold transition-all cursor-pointer hover:border-edge hover:text-txt" data-source={src}>
            {src} ({bySource[src].length})
          </button>
        ))}
      </div>

      <div id="noticias-list">
        {allItems.map((item: PrensaResumida) => (
          <a
            href={item.url}
            target="_blank"
            rel="noopener"
            class="ruled-item block noticias-item"
            data-cat={item.categoria}
            data-source={item.fuente_display || item.fuente}
          >
            <div class="flex items-center gap-2 flex-wrap text-[11px] text-txt-dim mb-1">
              <span class={`inline-flex items-center px-2 py-0.5 rounded text-[10px] font-semibold flex-shrink-0 ${categoriaPillClass(item.categoria)}`}>
                {item.categoria}
              </span>
              <span>{item.fuente_display}</span>
              <span class="text-edge">&middot;</span>
              <span>{item.fecha}</span>
            </div>
            <h3 class="font-display font-bold text-txt leading-snug">
              {item.titulo}
            </h3>
            {item.resumen && (
              <p class="text-sm text-txt-muted mt-1.5 line-clamp-3">
                {item.resumen}
              </p>
            )}
            {!item.resumen && item.contenido && (
              <p class="text-sm text-txt-muted mt-1.5 line-clamp-2">
                {item.contenido}
              </p>
            )}
          </a>
        ))}
      </div>
    </>
  ) : (
    <div class="border border-edge rounded-lg p-12 text-center">
      <h1 class="font-display text-2xl font-bold mb-2">Sin noticias</h1>
      <p class="text-txt-muted">No hay noticias disponibles para hoy. El scraping se ejecuta a las 7:00 AM Lima.</p>
    </div>
  )}
</Base>

<script>
  document.addEventListener("DOMContentLoaded", () => {
    const catFilters = document.querySelectorAll<HTMLButtonElement>(".noticias-filter");
    const srcFilters = document.querySelectorAll<HTMLButtonElement>(".noticias-source-filter");
    const items = document.querySelectorAll<HTMLElement>(".noticias-item");

    let activeCat = "all";
    let activeSource = "all";

    function applyFilters() {
      items.forEach((item) => {
        const matchCat = activeCat === "all" || item.dataset.cat === activeCat;
        const matchSrc = activeSource === "all" || item.dataset.source === activeSource;
        if (matchCat && matchSrc) {
          item.classList.remove("hidden");
        } else {
          item.classList.add("hidden");
        }
      });
    }

    catFilters.forEach((btn) => {
      btn.addEventListener("click", () => {
        catFilters.forEach((b) => b.classList.remove("active", "bg-loki-elevated", "text-txt"));
        btn.classList.add("active");
        activeCat = btn.dataset.filter || "all";
        applyFilters();
      });
    });

    srcFilters.forEach((btn) => {
      btn.addEventListener("click", () => {
        if (btn.classList.contains("bg-loki-elevated")) {
          btn.classList.remove("bg-loki-elevated", "text-txt", "border-edge");
          activeSource = "all";
        } else {
          srcFilters.forEach((b) => b.classList.remove("bg-loki-elevated", "text-txt", "border-edge"));
          btn.classList.add("bg-loki-elevated", "text-txt", "border-edge");
          activeSource = btn.dataset.source || "all";
        }
        applyFilters();
      });
    });
  });
</script>
