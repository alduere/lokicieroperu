---
import Base from "../../../layouts/Base.astro";
import { gacetaSortedDates, getGacetaDay, formatFechaEs } from "../../../lib/data";

const base = import.meta.env.BASE_URL.replace(/\/$/, "");
const days = gacetaSortedDates.map((d) => ({ date: d, dia: getGacetaDay(d)! }));
---

<Base title="Archivo · Gaceta PI · Loki" sourceSlug="indecopi" sourceName="INDECOPI">
  <nav class="text-xs text-txt-tertiary mb-4">
    <a href={`${base}/`} class="hover:text-txt">Inicio</a>
    <span class="mx-1">&rsaquo;</span>
    <a href={`${base}/indecopi/`} class="hover:text-txt">INDECOPI</a>
    <span class="mx-1">&rsaquo;</span>
    <a href={`${base}/indecopi/gaceta-pi/`} class="hover:text-txt">Gaceta PI</a>
    <span class="mx-1">&rsaquo;</span>
    <span class="text-txt">Archivo</span>
  </nav>

  <div class="mb-8">
    <h1 class="font-display text-4xl font-bold tracking-tightest">Archivo</h1>
    <p class="text-txt-tertiary mt-2">Historial de publicaciones de la Gaceta de Propiedad Industrial</p>
  </div>

  {days.length > 0 ? (
    <div class="overflow-hidden border-t-2 border-edge">
      <table class="w-full text-sm">
        <thead class="bg-loki-surface border-b-2 border-edge">
          <tr>
            <th class="text-left px-4 py-3 font-sans font-semibold text-txt-tertiary uppercase text-xs tracking-wider">Fecha</th>
            <th class="text-right px-4 py-3 font-sans font-semibold text-txt-tertiary uppercase text-xs tracking-wider">Solicitudes</th>
          </tr>
        </thead>
        <tbody>
          {days.map(({ date, dia }) => (
            <tr class="border-b border-edge hover:bg-loki-surface/50">
              <td class="px-4 py-3">
                <a href={`${base}/indecopi/gaceta-pi/`} class="font-display font-semibold text-txt hover:text-txt-secondary">
                  {formatFechaEs(date)}
                </a>
              </td>
              <td class="px-4 py-3 text-right font-mono text-txt-secondary">{dia.stats.total_solicitudes}</td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>
  ) : (
    <div class="border border-edge rounded-lg p-12 text-center">
      <p class="text-txt-secondary">Aun no hay datos de la Gaceta PI en el archivo.</p>
    </div>
  )}
</Base>
