---
import Base from "../../../layouts/Base.astro";
import { tfDays, tfSortedDates, formatFechaEs } from "../../../lib/data";
import type { ResolucionTFResumida } from "../../../lib/types";

export async function getStaticPaths() {
  const paths: { params: { id: string }; props: { resolucion: ResolucionTFResumida; fecha: string } }[] = [];
  for (const date of tfSortedDates) {
    const dia = tfDays[date];
    if (!dia) continue;
    for (const item of dia.items) {
      paths.push({ params: { id: item.id }, props: { resolucion: item, fecha: date } });
    }
  }
  return paths;
}

interface Props {
  resolucion: ResolucionTFResumida;
  fecha: string;
}

const { resolucion, fecha } = Astro.props;
const fechaEs = formatFechaEs(fecha);
const base = import.meta.env.BASE_URL.replace(/\/$/, "");
---

<Base title={`${resolucion.numero_rtf} · Tribunal Fiscal`} sourceSlug="tribunal-fiscal" sourceName="Tribunal Fiscal">
  <article class="max-w-3xl mx-auto" data-pagefind-body
    data-pagefind-meta={`title:${resolucion.numero_rtf}, sala:${resolucion.sala || ""}, fecha:${resolucion.fecha_rtf}, impacto:${resolucion.impacto}`}
    data-pagefind-filter={`fuente:Tribunal Fiscal,impacto:${resolucion.impacto},fecha:${resolucion.fecha_rtf}`}
  >
    <nav class="text-xs text-txt-dim mb-4">
      <a href={`${base}/`} class="hover:text-txt">Inicio</a>
      <span class="mx-1">&rsaquo;</span>
      <a href={`${base}/tribunal-fiscal/`} class="hover:text-txt">Tribunal Fiscal</a>
      <span class="mx-1">&rsaquo;</span>
      <span class="text-txt">{fechaEs}</span>
    </nav>

    <header class="border-b-2 border-edge pb-6 mb-6">
      <div class="flex items-center gap-2 text-xs uppercase tracking-widest text-txt-dim mb-3 flex-wrap">
        <span class={`impact-pill ${resolucion.impacto}`}>{resolucion.impacto} impacto</span>
        {resolucion.sala && <span>{resolucion.sala}</span>}
      </div>
      <h1 class="font-display text-2xl sm:text-3xl font-bold tracking-tight leading-snug mb-3">{resolucion.numero_rtf}</h1>
      {resolucion.sumilla && <p class="font-display text-base text-txt-muted italic leading-relaxed">{resolucion.sumilla}</p>}
    </header>

    {resolucion.resumen && (
      <section class="border-b border-edge pb-6 mb-6">
        <h2 class="text-xs uppercase tracking-widest text-txt-dim mb-3 font-semibold">Resumen</h2>
        <p class="text-base leading-relaxed text-txt">{resolucion.resumen}</p>
      </section>
    )}

    <section class="grid grid-cols-1 sm:grid-cols-2 gap-4 mb-6">
      {resolucion.sala && (
        <div class="border border-edge rounded-lg p-5">
          <h3 class="text-xs uppercase tracking-widest text-txt-dim mb-2 font-semibold">Sala</h3>
          <p class="text-sm text-txt font-medium">{resolucion.sala}</p>
        </div>
      )}
      {resolucion.numero_expediente && (
        <div class="border border-edge rounded-lg p-5">
          <h3 class="text-xs uppercase tracking-widest text-txt-dim mb-2 font-semibold">Expediente</h3>
          <p class="text-sm text-txt font-medium">{resolucion.numero_expediente}</p>
        </div>
      )}
      {resolucion.administracion && (
        <div class="border border-edge rounded-lg p-5 sm:col-span-2">
          <h3 class="text-xs uppercase tracking-widest text-txt-dim mb-2 font-semibold">Administracion</h3>
          <p class="text-sm text-txt">{resolucion.administracion}</p>
        </div>
      )}
      {resolucion.tema_tributario && (
        <div class="border border-edge rounded-lg p-5 sm:col-span-2">
          <h3 class="text-xs uppercase tracking-widest text-txt-dim mb-2 font-semibold">Tema tributario</h3>
          <p class="text-sm text-txt">{resolucion.tema_tributario}</p>
        </div>
      )}
    </section>

    {(resolucion.tags?.length > 0 || resolucion.impacto_razon) && (
      <section class="border-b border-edge pb-6 mb-6">
        {resolucion.impacto_razon && (
          <div class="mb-3">
            <h3 class="text-xs uppercase tracking-widest text-txt-dim mb-1 font-semibold">Nivel de impacto</h3>
            <p class="text-sm text-txt">{resolucion.impacto_razon}</p>
          </div>
        )}
        {resolucion.tags?.length > 0 && (
          <div>
            {resolucion.tags.map((t) => (
              <span class="inline-block px-2 py-1 text-xs bg-loki-surface border border-edge text-txt-muted rounded-md mr-1 mb-1">#{t}</span>
            ))}
          </div>
        )}
      </section>
    )}

    <div class="flex items-center justify-center gap-4 mt-8 flex-wrap">
      {resolucion.link_pdf && (
        <a href={resolucion.link_pdf} class="inline-flex items-center gap-2 px-5 py-3 bg-loki-elevated text-txt rounded-lg font-semibold text-sm hover:bg-loki-elevated transition-colors" target="_blank" rel="noopener noreferrer">
          Descargar PDF
        </a>
      )}
      {resolucion.link_sumilla && (
        <a href={resolucion.link_sumilla} class="inline-flex items-center gap-2 px-5 py-3 border border-edge rounded-lg font-semibold text-sm hover:bg-loki-surface transition-colors" target="_blank" rel="noopener noreferrer">
          Ver sumilla &rarr;
        </a>
      )}
    </div>
  </article>
</Base>
