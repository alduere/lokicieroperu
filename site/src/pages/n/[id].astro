---
import Base from "../../layouts/Base.astro";
import { allNorms, formatFechaEs } from "../../lib/data";
import type { NormaResumida } from "../../lib/types";

export async function getStaticPaths() {
  return allNorms().map((n) => ({
    params: { id: n.id },
    props: { norma: n, fecha: n._fecha },
  }));
}

interface Props {
  norma: NormaResumida;
  fecha: string;
}

const { norma, fecha } = Astro.props;
const fechaEs = formatFechaEs(norma.fecha_publicacion);
const base = import.meta.env.BASE_URL.replace(/\/$/, "");
---

<Base title={`${norma.tipo_corto}${norma.numero ? ` ${norma.numero}` : ""} · NotiRelevantePerú`}>
  <article
    class="max-w-3xl mx-auto"
    data-pagefind-body
    data-pagefind-meta={`title:${norma.tipo_corto}${norma.numero ? " " + norma.numero : ""}, entidad:${norma.entidad_emisora}, fecha:${norma.fecha_publicacion}, impacto:${norma.impacto}`}
    data-pagefind-filter={`tipo:${norma.tipo_corto},impacto:${norma.impacto},fecha:${norma.fecha_publicacion}`}
  >
    <nav class="text-xs text-ink-500 mb-4">
      <a href={`${base}/${fecha}`} class="hover:text-ink-900">← {fechaEs}</a>
    </nav>

    <header class="glass p-6 sm:p-8 mb-6">
      <div class="flex items-center gap-2 text-xs uppercase tracking-widest text-ink-500 mb-3 flex-wrap">
        <span class={`impact-pill ${norma.impacto}`}>{norma.impacto} impacto</span>
        <span data-pagefind-filter={`tipo:${norma.tipo_corto}`}>{norma.tipo_corto}</span>
        {norma.numero && <span>· N° {norma.numero}</span>}
        {norma.edicion_extraordinaria && <span class="text-impact-alto font-bold">· EDICIÓN EXTRAORDINARIA</span>}
      </div>
      <div class="text-xs uppercase tracking-widest text-ink-700 font-semibold mb-2" data-pagefind-filter={`entidad:${norma.entidad_emisora}`}>
        {norma.entidad_emisora}
      </div>
      <h1 class="text-2xl sm:text-3xl font-bold tracking-tight leading-snug mb-3">{norma.titulo_oficial}</h1>
      <p class="text-base text-ink-700 italic leading-relaxed">{norma.sumilla}</p>
    </header>

    {norma.resumen_ejecutivo && (
      <section class="glass p-6 sm:p-8 mb-6">
        <h2 class="text-xs uppercase tracking-widest text-ink-500 mb-3 font-semibold">Resumen ejecutivo</h2>
        <p class="text-base leading-relaxed text-ink-900">{norma.resumen_ejecutivo}</p>
      </section>
    )}

    {(norma.cambios_clave?.length > 0 || norma.a_quien_afecta || norma.vigencia) && (
      <section class="grid grid-cols-1 sm:grid-cols-3 gap-4 mb-6">
        {norma.cambios_clave?.length > 0 && (
          <div class="glass p-5 sm:col-span-3">
            <h3 class="text-xs uppercase tracking-widest text-ink-500 mb-2 font-semibold">Cambios clave</h3>
            <ul class="space-y-1 text-sm text-ink-900">
              {norma.cambios_clave.map((c) => (
                <li class="flex gap-2">
                  <span class="text-ink-400">→</span>
                  <span>{c}</span>
                </li>
              ))}
            </ul>
          </div>
        )}
        {norma.a_quien_afecta && (
          <div class="glass p-5">
            <h3 class="text-xs uppercase tracking-widest text-ink-500 mb-2 font-semibold">A quién afecta</h3>
            <p class="text-sm text-ink-900">{norma.a_quien_afecta}</p>
          </div>
        )}
        {norma.vigencia && (
          <div class="glass p-5">
            <h3 class="text-xs uppercase tracking-widest text-ink-500 mb-2 font-semibold">Vigencia</h3>
            <p class="text-sm text-ink-900">{norma.vigencia}</p>
          </div>
        )}
        {norma.impacto_razon && (
          <div class="glass p-5">
            <h3 class="text-xs uppercase tracking-widest text-ink-500 mb-2 font-semibold">Por qué este impacto</h3>
            <p class="text-sm text-ink-900">{norma.impacto_razon}</p>
          </div>
        )}
      </section>
    )}

    {(norma.sectores?.length > 0 || norma.tags?.length > 0) && (
      <section class="glass p-6 mb-6">
        <h3 class="text-xs uppercase tracking-widest text-ink-500 mb-3 font-semibold">Clasificación</h3>
        {norma.sectores?.length > 0 && (
          <div class="mb-2">
            {norma.sectores.map((s) => (
              <span class="inline-block px-2 py-1 text-xs font-semibold bg-ink-100 text-ink-800 rounded-md mr-1.5 mb-1" data-pagefind-filter={`sector:${s}`}>
                {s.replace(/_/g, " ")}
              </span>
            ))}
          </div>
        )}
        {norma.tags?.length > 0 && (
          <div>
            {norma.tags.map((t) => (
              <span class="inline-block px-2 py-1 text-xs bg-ink-50 text-ink-600 rounded-md mr-1 mb-1">#{t}</span>
            ))}
          </div>
        )}
      </section>
    )}

    {norma.link_oficial && (
      <div class="text-center mt-8">
        <a href={norma.link_oficial} class="inline-flex items-center gap-2 px-5 py-3 bg-ink-900 text-white rounded-lg font-semibold text-sm hover:bg-ink-700 transition-colors" target="_blank" rel="noopener noreferrer">
          Ver texto oficial en El Peruano →
        </a>
      </div>
    )}
  </article>
</Base>
