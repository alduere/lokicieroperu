---
import Base from "../layouts/Base.astro";
---

<Base title="Buscar · Loki">
  <div class="max-w-4xl mx-auto">
    <h1 class="font-display text-4xl font-bold tracking-tightest mb-2">Buscar en todas las fuentes</h1>
    <p class="text-txt-dim mb-8">Busqueda full-text en todas las fuentes del hub</p>

    <div id="search" class="mb-8"></div>

    <link href="/lokicieroperu/pagefind/pagefind-ui.css" rel="stylesheet">
    <script is:inline src="/lokicieroperu/pagefind/pagefind-ui.js"></script>
    <script is:inline>
      window.addEventListener("DOMContentLoaded", () => {
        if (typeof PagefindUI !== "undefined") {
          new PagefindUI({
            element: "#search",
            showSubResults: true,
            showImages: false,
            resetStyles: false,
            bundlePath: "/lokicieroperu/pagefind/",
            translations: {
              placeholder: "Buscar en todas las fuentes...",
              clear_search: "Limpiar",
              load_more: "Cargar mas resultados",
              search_label: "Buscar en Loki",
              filters_label: "Filtros",
              zero_results: "Sin resultados para [SEARCH_TERM]",
              many_results: "[COUNT] resultados para [SEARCH_TERM]",
              one_result: "1 resultado para [SEARCH_TERM]",
              alt_search: "Sin resultados para [SEARCH_TERM]. Mostrando resultados para [DIFFERENT_TERM]",
              search_suggestion: "Sin resultados para [SEARCH_TERM]. Pruebe una busqueda diferente",
              searching: "Buscando [SEARCH_TERM]...",
            },
          });
        }
      });
    </script>
  </div>
</Base>

<style is:global>
  /* Custom Pagefind UI tweaks for dark theme */
  :root {
    --pagefind-ui-scale: 1;
    --pagefind-ui-primary: #818cf8;
    --pagefind-ui-text: #e8e8ec;
    --pagefind-ui-background: #14151c;
    --pagefind-ui-border: #25262f;
    --pagefind-ui-tag: #1c1d26;
    --pagefind-ui-border-width: 1px;
    --pagefind-ui-border-radius: 8px;
    --pagefind-ui-image-border-radius: 8px;
    --pagefind-ui-image-box-ratio: 3 / 2;
    --pagefind-ui-font: "DM Sans", system-ui, sans-serif;
  }
  .pagefind-ui__search-input {
    font-weight: 500;
    border-radius: 8px;
    padding: 14px 18px;
    background: #1c1d26;
    color: #e8e8ec;
  }
  .pagefind-ui__filter-panel {
    margin-top: 1rem;
  }
  .pagefind-ui__filter-group {
    border: 1px solid #25262f;
    border-radius: 8px;
    padding: 12px 16px;
    margin-bottom: 8px;
  }
  .pagefind-ui__result {
    border-bottom: 1px solid #25262f;
    padding: 16px 0;
    margin-bottom: 0;
  }
  .pagefind-ui__result-link {
    font-family: "Bricolage Grotesque", system-ui, sans-serif;
    font-size: 18px;
    font-weight: 700;
    color: #e8e8ec;
  }
  .pagefind-ui__result-excerpt {
    font-size: 14px;
    line-height: 1.6;
    color: #8b8c99;
  }
</style>
