---
import Base from "../layouts/Base.astro";
---

<Base title="Buscar · NotiRelevantePerú">
  <div class="max-w-4xl mx-auto">
    <h1 class="text-4xl font-bold tracking-tightest mb-2">Buscar normas</h1>
    <p class="text-ink-500 mb-8">Búsqueda full-text con filtros por tipo, impacto, sector y entidad</p>

    <div id="search" class="mb-8"></div>

    <link href="/notirelevanteperu/pagefind/pagefind-ui.css" rel="stylesheet">
    <script is:inline src="/notirelevanteperu/pagefind/pagefind-ui.js"></script>
    <script is:inline>
      window.addEventListener("DOMContentLoaded", () => {
        if (typeof PagefindUI !== "undefined") {
          new PagefindUI({
            element: "#search",
            showSubResults: true,
            showImages: false,
            resetStyles: false,
            bundlePath: "/notirelevanteperu/pagefind/",
            translations: {
              placeholder: "Buscar por palabra clave, entidad, sector...",
              clear_search: "Limpiar",
              load_more: "Cargar más resultados",
              search_label: "Buscar en NotiRelevantePerú",
              filters_label: "Filtros",
              zero_results: "Sin resultados para [SEARCH_TERM]",
              many_results: "[COUNT] resultados para [SEARCH_TERM]",
              one_result: "1 resultado para [SEARCH_TERM]",
              alt_search: "Sin resultados para [SEARCH_TERM]. Mostrando resultados para [DIFFERENT_TERM]",
              search_suggestion: "Sin resultados para [SEARCH_TERM]. Pruebe una búsqueda diferente",
              searching: "Buscando [SEARCH_TERM]...",
            },
          });
        }
      });
    </script>
  </div>
</Base>

<style is:global>
  /* Custom Pagefind UI tweaks to match the bento aesthetic */
  :root {
    --pagefind-ui-scale: 1;
    --pagefind-ui-primary: #0f172a;
    --pagefind-ui-text: #0f172a;
    --pagefind-ui-background: #ffffff;
    --pagefind-ui-border: #e2e8f0;
    --pagefind-ui-tag: #f1f5f9;
    --pagefind-ui-border-width: 1px;
    --pagefind-ui-border-radius: 12px;
    --pagefind-ui-image-border-radius: 8px;
    --pagefind-ui-image-box-ratio: 3 / 2;
    --pagefind-ui-font: "Inter", system-ui, sans-serif;
  }
  .pagefind-ui__search-input {
    font-weight: 500;
    border-radius: 12px;
    padding: 14px 18px;
  }
  .pagefind-ui__filter-panel {
    margin-top: 1rem;
  }
  .pagefind-ui__filter-group {
    border: 1px solid #e2e8f0;
    border-radius: 12px;
    padding: 12px 16px;
    margin-bottom: 8px;
  }
  .pagefind-ui__result {
    border: 1px solid #e2e8f0;
    border-radius: 12px;
    padding: 16px;
    margin-bottom: 12px;
  }
  .pagefind-ui__result-link {
    font-size: 16px;
    font-weight: 700;
    color: #0f172a;
  }
  .pagefind-ui__result-excerpt {
    font-size: 14px;
    line-height: 1.5;
  }
</style>
