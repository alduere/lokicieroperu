---
import Base from "../../layouts/Base.astro";
import StatsHero from "../../components/StatsHero.astro";
import BentoGrid from "../../components/BentoGrid.astro";
import FilterBar from "../../components/FilterBar.astro";
import { latestEpDate, getEpDay } from "../../lib/data";

const date = latestEpDate();
const dia = date ? getEpDay(date) : null;
const base = import.meta.env.BASE_URL.replace(/\/$/, "");
---

<Base title={dia ? `El Peruano · Loki-ciero Perú · ${dia.fecha}` : "El Peruano · Loki-ciero Perú"} sourceSlug="elperuano" sourceName="El Peruano">
  <nav class="text-xs text-ink-500 mb-4">
    <a href={`${base}/`} class="hover:text-ink-900">Inicio</a>
    <span class="mx-1">›</span>
    <span class="text-ink-700">El Peruano</span>
  </nav>

  {dia ? (
    <>
      <StatsHero dia={dia} />
      <FilterBar normas={dia.normas} />
      <BentoGrid dia={dia} />
    </>
  ) : (
    <div class="glass p-12 text-center">
      <h1 class="text-2xl font-bold mb-2">Sin datos todavía</h1>
      <p class="text-ink-600">El primer scraping aún no se ha ejecutado. Vuelve mañana después de las 7:00 AM Lima.</p>
    </div>
  )}
</Base>
