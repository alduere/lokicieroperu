---
import Base from "../../layouts/Base.astro";
import StatsHero from "../../components/StatsHero.astro";
import BentoGrid from "../../components/BentoGrid.astro";
import FilterBar from "../../components/FilterBar.astro";
import { epSortedDates, getEpDay } from "../../lib/data";

export async function getStaticPaths() {
  return epSortedDates
    .filter((date) => date && /^\d{4}-\d{2}-\d{2}$/.test(date))
    .map((date) => ({
      params: { date },
      props: { dia: getEpDay(date) },
    }));
}

const { dia } = Astro.props;
const base = import.meta.env.BASE_URL.replace(/\/$/, "");
---

<Base title={`El Peruano ÂṖ Lokiẃ ÂṖ ${dia.fecha}`} sourceSlug="elperuano" sourceName="El Peruano">
  <nav class="text-xs text-txt-tertiary mb-4">
    <a href={`${base}/`} class="hover:text-txt">Inicio</a>
    <span class="mx-1">âẃ</span>
    <a href={`${base}/elperuano/`} class="hover:text-txt">El Peruano</a>
  </nav>

  <StatsHero dia={dia} />
  <FilterBar normas={dia.normas} />
  <BentoGrid dia={dia} />
</Base>
