---
import Base from "../../layouts/Base.astro";

const base = import.meta.env.BASE_URL.replace(/\/$/, "");
---

<Base title="Buscar en El Peruano · Loki-ciero Perú" sourceSlug="elperuano" sourceName="El Peruano">
  <div class="max-w-4xl mx-auto">
    <nav class="text-xs text-ink-sepia mb-4">
      <a href={`${base}/`} class="hover:text-ink">Inicio</a>
      <span class="mx-1">›</span>
      <a href={`${base}/elperuano/`} class="hover:text-ink">El Peruano</a>
      <span class="mx-1">›</span>
      <span class="text-ink">Buscar</span>
    </nav>

    <h1 class="font-display text-4xl font-bold tracking-tightest mb-2">Buscar en El Peruano</h1>
    <p class="text-ink-sepia mb-8">Búsqueda full-text con filtros por tipo, impacto, sector y entidad</p>

    <div id="search" class="mb-8"></div>

    <link href="/lokicieroperu/pagefind/pagefind-ui.css" rel="stylesheet">
    <script is:inline src="/lokicieroperu/pagefind/pagefind-ui.js"></script>
    <script is:inline>
      window.addEventListener("DOMContentLoaded", () => {
        if (typeof PagefindUI !== "undefined") {
          new PagefindUI({
            element: "#search",
            showSubResults: true,
            showImages: false,
            resetStyles: false,
            bundlePath: "/lokicieroperu/pagefind/",
            translations: {
              placeholder: "Buscar normas en El Peruano...",
              clear_search: "Limpiar",
              load_more: "Cargar más resultados",
              search_label: "Buscar en El Peruano",
              filters_label: "Filtros",
              zero_results: "Sin resultados para [SEARCH_TERM]",
              many_results: "[COUNT] resultados para [SEARCH_TERM]",
              one_result: "1 resultado para [SEARCH_TERM]",
              alt_search: "Sin resultados para [SEARCH_TERM]. Mostrando resultados para [DIFFERENT_TERM]",
              search_suggestion: "Sin resultados para [SEARCH_TERM]. Pruebe una búsqueda diferente",
              searching: "Buscando [SEARCH_TERM]...",
            },
          });
        }
      });
    </script>
  </div>
</Base>

<style is:global>
  /* Custom Pagefind UI tweaks to match the editorial aesthetic */
  :root {
    --pagefind-ui-scale: 1;
    --pagefind-ui-primary: #2c1810;
    --pagefind-ui-text: #2c1810;
    --pagefind-ui-background: #faf5eb;
    --pagefind-ui-border: #c4b69c;
    --pagefind-ui-tag: #f5f0e6;
    --pagefind-ui-border-width: 1px;
    --pagefind-ui-border-radius: 4px;
    --pagefind-ui-image-border-radius: 4px;
    --pagefind-ui-image-box-ratio: 3 / 2;
    --pagefind-ui-font: "Source Sans 3", system-ui, sans-serif;
  }
  .pagefind-ui__search-input {
    font-weight: 500;
    border-radius: 4px;
    padding: 14px 18px;
  }
  .pagefind-ui__filter-panel {
    margin-top: 1rem;
  }
  .pagefind-ui__filter-group {
    border: 1px solid #c4b69c;
    border-radius: 4px;
    padding: 12px 16px;
    margin-bottom: 8px;
  }
  .pagefind-ui__result {
    border-bottom: 1px solid #c4b69c;
    padding: 16px 0;
    margin-bottom: 0;
  }
  .pagefind-ui__result-link {
    font-family: "Playfair Display", serif;
    font-size: 18px;
    font-weight: 700;
    color: #2c1810;
  }
  .pagefind-ui__result-excerpt {
    font-size: 14px;
    line-height: 1.6;
    color: #5a4a3a;
  }
</style>
