---
import Base from "../../layouts/Base.astro";
import { latestIndecopiDate, getIndecopiDay, formatFechaEs } from "../../lib/data";
import type { AlertaResumida } from "../../lib/types";

const date = latestIndecopiDate();
const dia = date ? getIndecopiDay(date) : null;
const base = import.meta.env.BASE_URL.replace(/\/$/, "");
---

<Base title={dia ? `INDECOPI Alertas · ${dia.fecha}` : "INDECOPI Alertas · Loki-ciero Perú"} sourceSlug="indecopi-alertas" sourceName="Alertas">
  <nav class="text-xs text-ink-sepia mb-4">
    <a href={`${base}/`} class="hover:text-ink">Inicio</a>
    <span class="mx-1">›</span>
    <span class="text-ink">INDECOPI Alertas</span>
  </nav>

  {dia && dia.items.length > 0 ? (
    <>
      <div class="border-b-2 border-ink pb-6 mb-8">
        <div class="text-xs uppercase tracking-widest text-ink-sepia mb-1">{formatFechaEs(dia.fecha)}</div>
        <h1 class="font-display text-4xl sm:text-5xl font-black tracking-tightest mb-3">Alertas de consumo</h1>
        <div class="flex items-center gap-6 text-sm text-ink-light">
          <div><span class="font-display text-3xl font-bold text-ink">{dia.stats.total_alertas}</span> alertas</div>
        </div>
      </div>

      <div class="divide-y divide-ink-rule">
        {dia.items.map((alerta: AlertaResumida) => (
          <a href={`${base}/indecopi-alertas/item/${alerta.id}`} class="ruled-item block py-5 hover:bg-parchment-light/50 transition-colors">
            <div class="flex items-start justify-between gap-4">
              <div class="flex-1">
                <div class="flex items-center gap-2 mb-2">
                  <span class={`impact-pill ${alerta.impacto}`}>{alerta.impacto}</span>
                  {alerta.categoria && (
                    <span class="text-xs px-2 py-0.5 bg-parchment-light border border-ink-rule-light text-ink-light rounded-full">{alerta.categoria}</span>
                  )}
                </div>
                <h2 class="font-display font-bold text-lg leading-snug mb-1">{alerta.titulo}</h2>
                {alerta.resumen ? (
                  <p class="text-sm text-ink-light line-clamp-2">{alerta.resumen}</p>
                ) : alerta.sumilla ? (
                  <p class="text-sm text-ink-light line-clamp-2">{alerta.sumilla}</p>
                ) : null}
                <div class="flex items-center gap-3 mt-2 text-xs text-ink-sepia">
                  {alerta.marca && <span>Marca: {alerta.marca}</span>}
                  {alerta.nombre_producto && <span>Producto: {alerta.nombre_producto}</span>}
                </div>
              </div>
            </div>
          </a>
        ))}
      </div>
    </>
  ) : (
    <div class="border border-ink-rule rounded-lg p-12 text-center">
      <h1 class="font-display text-2xl font-bold mb-2">Sin alertas</h1>
      <p class="text-ink-light">No hay alertas de consumo para hoy. INDECOPI publica alertas según se detectan riesgos.</p>
    </div>
  )}
</Base>
