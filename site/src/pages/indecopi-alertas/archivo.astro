---
import Base from "../../layouts/Base.astro";
import { indecopiSortedDates, getIndecopiDay, formatFechaEs } from "../../lib/data";

const base = import.meta.env.BASE_URL.replace(/\/$/, "");
const days = indecopiSortedDates.map((d) => ({ date: d, dia: getIndecopiDay(d)! }));
---

<Base title="Archivo · INDECOPI Alertas · Loki-ciero Perú" sourceSlug="indecopi-alertas" sourceName="Alertas">
  <nav class="text-xs text-ink-500 mb-4">
    <a href={`${base}/`} class="hover:text-ink-900">Inicio</a>
    <span class="mx-1">›</span>
    <a href={`${base}/indecopi-alertas/`} class="hover:text-ink-900">INDECOPI Alertas</a>
    <span class="mx-1">›</span>
    <span class="text-ink-700">Archivo</span>
  </nav>

  <div class="mb-8">
    <h1 class="text-4xl font-bold tracking-tightest">Archivo</h1>
    <p class="text-ink-500 mt-2">Historial de alertas de consumo de INDECOPI</p>
  </div>

  {days.length > 0 ? (
    <div class="glass overflow-hidden">
      <table class="w-full text-sm">
        <thead class="bg-ink-50 border-b border-ink-200">
          <tr>
            <th class="text-left px-4 py-3 font-semibold text-ink-700 uppercase text-xs tracking-wider">Fecha</th>
            <th class="text-right px-4 py-3 font-semibold text-ink-700 uppercase text-xs tracking-wider">Alertas</th>
          </tr>
        </thead>
        <tbody>
          {days.map(({ date, dia }) => (
            <tr class="border-b border-ink-100 hover:bg-ink-50">
              <td class="px-4 py-3">
                <a href={`${base}/indecopi-alertas/`} class="font-semibold text-ink-900 hover:text-ink-700">
                  {formatFechaEs(date)}
                </a>
              </td>
              <td class="px-4 py-3 text-right font-mono">{dia.stats.total_alertas}</td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>
  ) : (
    <div class="glass p-12 text-center">
      <p class="text-ink-600">Aún no hay datos de alertas en el archivo.</p>
    </div>
  )}
</Base>
