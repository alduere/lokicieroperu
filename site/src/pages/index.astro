---
import Base from "../layouts/Base.astro";
import { latestHubDate, getHubDay, formatFechaEs, getEpDay, getIndecopiDay, getConsumidorDay, getGacetaDay } from "../lib/data";
import type { NormaResumida, AlertaResumida, NoticiaResumida, SolicitudPIResumida, Impacto } from "../lib/types";

const date = latestHubDate();
const hub = date ? getHubDay(date) : null;
const base = import.meta.env.BASE_URL.replace(/\/$/, "");

// Load source-specific data for item lists
const epDay = date ? getEpDay(date) : null;
const indecopiDay = date ? getIndecopiDay(date) : null;

// El Peruano: sort by impact (alto first), take top 5
const impactOrder: Record<Impacto, number> = { alto: 0, medio: 1, bajo: 2 };
const epItems = epDay
  ? [...epDay.normas]
      .sort((a, b) => impactOrder[a.impacto] - impactOrder[b.impacto])
      .slice(0, 5)
  : [];
const epTotal = epDay ? epDay.normas.length : 0;
const epRemaining = epTotal - epItems.length;

// INDECOPI: show all items
const indecopiItems = indecopiDay ? indecopiDay.items : [];
const indecopiTotal = indecopiItems.length;

// Consumidor: load source data
const consumidorDay = date ? getConsumidorDay(date) : null;
const consumidorItems = consumidorDay ? consumidorDay.items : [];
const consumidorTotal = consumidorItems.length;

// Gaceta PI: load source data, show top 10 on hub
const gacetaDay = date ? getGacetaDay(date) : null;
const gacetaItemsAll = gacetaDay ? gacetaDay.items : [];
const gacetaVisible = gacetaItemsAll.slice(0, 10);
const gacetaTotal = gacetaItemsAll.length;
const gacetaRemaining = gacetaTotal - gacetaVisible.length;

// Hub source metadata
const epSource = hub?.sources.find((s) => s.slug === "elperuano");
const indecopiSource = hub?.sources.find((s) => s.slug === "indecopi-alertas");
const consumidorSource = hub?.sources.find((s) => s.slug === "consumidor");
const gacetaSource = hub?.sources.find((s) => s.slug === "gaceta-pi");

function impactLabel(impacto: Impacto): string {
  return impacto.charAt(0).toUpperCase() + impacto.slice(1);
}
---

<Base title={hub ? `Loki-ciero Peru · ${hub.fecha}` : "Loki-ciero Peru"}>
  {hub ? (
    <>
      {/* Hero */}
      <section class="text-center py-6">
        <div class="text-xs uppercase tracking-[0.25em] text-ink-sepia font-sans mb-3">
          Resumen del día
        </div>
        <h1 class="font-display font-black text-4xl sm:text-5xl tracking-tightest leading-none mb-6">
          {formatFechaEs(hub.fecha)}
        </h1>
        <div class="flex justify-center gap-8 sm:gap-12 text-center">
          <div>
            <div class="font-display font-black text-3xl leading-none">{hub.stats.total_publicaciones}</div>
            <div class="text-xs uppercase tracking-widest text-ink-sepia mt-1 font-sans">Publicaciones</div>
          </div>
          <div>
            <div class="font-display font-black text-3xl leading-none text-impact-alto">{hub.stats.alertas_alto}</div>
            <div class="text-xs uppercase tracking-widest text-ink-sepia mt-1 font-sans">Alto impacto</div>
          </div>
          <div>
            <div class="font-display font-black text-3xl leading-none">{hub.stats.fuentes_activas}</div>
            <div class="text-xs uppercase tracking-widest text-ink-sepia mt-1 font-sans">Fuentes activas</div>
          </div>
        </div>
      </section>

      <div class="section-divider"><span></span></div>

      {/* El Peruano source block */}
      {epSource && epSource.total > 0 && (
        <div class="source-block mb-12" data-source="elperuano">
          {/* Source header */}
          <div class="border-b-2 border-ink pb-2 mb-1 flex items-end justify-between">
            <div>
              <h2 class="font-display font-black text-2xl tracking-tightest leading-none">
                {epSource.nombre}
              </h2>
            </div>
            <div class="font-display font-black text-3xl leading-none">
              {epSource.total}
            </div>
          </div>
          <div class="font-display italic text-ink-sepia text-sm mb-3">
            {epSource.subtitulo}
          </div>

          {/* Impact pills */}
          {epSource.categorias.length > 0 && (
            <div class="flex gap-2 mb-4">
              {epSource.categorias.map((cat) => (
                <span class={`impact-pill ${cat.nombre}`}>
                  {impactLabel(cat.nombre as Impacto)} {cat.count}
                </span>
              ))}
            </div>
          )}

          {/* Item list */}
          <div>
            {epItems.map((norma) => (
              <a
                href={`${base}/elperuano/n/${norma.id}`}
                class="ruled-item block"
              >
                <div class="flex items-start gap-2 mb-1">
                  <span class={`impact-pill ${norma.impacto} flex-shrink-0`}>
                    {impactLabel(norma.impacto)}
                  </span>
                  <span class="font-display font-bold text-ink leading-snug">
                    {norma.titulo_oficial}
                  </span>
                </div>
                <div class="text-xs text-ink-sepia ml-0 mt-1">
                  {norma.tipo_corto} · {norma.entidad_emisora}
                </div>
                {(norma.impacto === "alto" || norma.impacto === "medio") && norma.resumen_ejecutivo && (
                  <p class="text-sm text-ink-light mt-1.5 line-clamp-2">
                    {norma.resumen_ejecutivo}
                  </p>
                )}
              </a>
            ))}
          </div>

          {epRemaining > 0 && (
            <a
              href={`${base}/elperuano/`}
              class="inline-block mt-4 text-sm font-semibold text-ink-sepia hover:text-ink transition-colors"
            >
              + {epRemaining} más &rarr;
            </a>
          )}
        </div>
      )}

      {/* INDECOPI combined source block */}
      {(indecopiTotal + consumidorTotal + gacetaTotal) > 0 && (
        <div class="source-block mb-12" data-source="indecopi">
          {/* Source header */}
          <div class="border-b-2 border-ink pb-2 mb-1 flex items-end justify-between">
            <div>
              <h2 class="font-display font-black text-2xl tracking-tightest leading-none">
                INDECOPI
              </h2>
            </div>
            <div class="font-display font-black text-3xl leading-none">
              {indecopiTotal + consumidorTotal + gacetaTotal}
            </div>
          </div>
          <div class="font-display italic text-ink-sepia text-sm mb-3">
            Alertas, proteccion al consumidor, propiedad industrial
          </div>

          {/* Alertas mini-section */}
          {indecopiTotal > 0 && (
            <div class="mb-6">
              <div class="flex items-center justify-between mb-2">
                <h3 class="text-xs uppercase tracking-widest text-ink-sepia font-semibold">Alertas</h3>
                <span class="text-xs text-ink-sepia">{indecopiTotal}</span>
              </div>
              <div>
                {indecopiItems.slice(0, 3).map((item) => (
                  <a
                    href={`${base}/indecopi/alertas/item/${item.id}`}
                    class="ruled-item block"
                  >
                    <div class="flex items-start gap-2 mb-1">
                      <span class={`impact-pill ${item.impacto} flex-shrink-0`}>
                        {impactLabel(item.impacto)}
                      </span>
                      <span class="font-display font-bold text-ink leading-snug">
                        {item.titulo}
                      </span>
                    </div>
                    <div class="text-xs text-ink-sepia ml-0 mt-1">
                      {item.categoria || "Alerta"} &middot; {item.marca || "Sin marca"}
                    </div>
                  </a>
                ))}
              </div>
              {indecopiTotal > 3 && (
                <a href={`${base}/indecopi/alertas/`} class="inline-block mt-2 text-xs font-semibold text-ink-sepia hover:text-ink transition-colors">
                  + {indecopiTotal - 3} mas &rarr;
                </a>
              )}
            </div>
          )}

          {/* Consumidor mini-section */}
          {consumidorTotal > 0 && (
            <div class="mb-6">
              <div class="flex items-center justify-between mb-2">
                <h3 class="text-xs uppercase tracking-widest text-ink-sepia font-semibold">Consumidor</h3>
                <span class="text-xs text-ink-sepia">{consumidorTotal}</span>
              </div>
              <div>
                {consumidorItems.slice(0, 3).map((noticia) => (
                  <div class="ruled-item block">
                    <div class="flex items-start gap-2 mb-1">
                      <span class={`impact-pill ${noticia.impacto} flex-shrink-0`}>
                        {impactLabel(noticia.impacto)}
                      </span>
                      <span class="font-display font-bold text-ink leading-snug">
                        {noticia.titulo}
                      </span>
                    </div>
                  </div>
                ))}
              </div>
              {consumidorTotal > 3 && (
                <a href={`${base}/indecopi/consumidor/`} class="inline-block mt-2 text-xs font-semibold text-ink-sepia hover:text-ink transition-colors">
                  + {consumidorTotal - 3} mas &rarr;
                </a>
              )}
            </div>
          )}

          {/* Gaceta PI mini-section */}
          {gacetaTotal > 0 && (
            <div class="mb-6">
              <div class="flex items-center justify-between mb-2">
                <h3 class="text-xs uppercase tracking-widest text-ink-sepia font-semibold">Gaceta PI</h3>
                <span class="text-xs text-ink-sepia">{gacetaTotal}</span>
              </div>
              <div>
                {gacetaVisible.slice(0, 5).map((item) => (
                  <a
                    href={`${base}/indecopi/gaceta-pi/item/${item.id}`}
                    class="ruled-item block"
                  >
                    <div class="flex items-start gap-2 mb-1">
                      <span class="text-xs px-2 py-0.5 bg-parchment-light border border-ink-rule-light text-ink-light rounded-full flex-shrink-0">
                        {item.tipo_solicitud}
                      </span>
                      <span class="font-display font-bold text-ink leading-snug">
                        {item.signo_solicitado}
                      </span>
                    </div>
                    <div class="text-xs text-ink-sepia ml-0 mt-1">
                      {item.solicitante}{item.clase ? ` &middot; Clase ${item.clase}` : ""}
                    </div>
                  </a>
                ))}
              </div>
              {gacetaTotal > 5 && (
                <a href={`${base}/indecopi/gaceta-pi/`} class="inline-block mt-2 text-xs font-semibold text-ink-sepia hover:text-ink transition-colors">
                  + {gacetaTotal - 5} mas &rarr;
                </a>
              )}
            </div>
          )}

          <a
            href={`${base}/indecopi/`}
            class="inline-block mt-2 text-sm font-semibold text-ink-sepia hover:text-ink transition-colors"
          >
            + Ver todo en INDECOPI &rarr;
          </a>
        </div>
      )}

      {/* Fallback: sources with zero items */}
      {hub.sources.filter((s) => s.total === 0).length > 0 && (
        <div class="section-divider"><span>Sin novedades hoy</span></div>
      )}
      {hub.sources.filter((s) => s.total === 0).map((source) => {
        const mapped = source.slug === "indecopi-alertas" || source.slug === "consumidor" || source.slug === "gaceta-pi" ? "indecopi" : source.slug;
        return (
          <div class="source-block mb-6 opacity-50" data-source={mapped}>
            <div class="border-b border-ink-rule pb-2 flex items-end justify-between">
              <h2 class="font-display font-bold text-lg tracking-tightest">{source.nombre}</h2>
              <div class="font-display font-black text-xl leading-none text-ink-sepia">0</div>
            </div>
            <div class="font-display italic text-ink-sepia text-sm mt-1">{source.subtitulo}</div>
          </div>
        );
      })}
    </>
  ) : (
    <section class="text-center py-16">
      <h1 class="font-display font-black text-3xl mb-3">Sin datos todavía</h1>
      <p class="text-ink-sepia font-sans">
        El primer scraping aún no se ha ejecutado. Vuelve mañana después de las 7:00 AM Lima.
      </p>
    </section>
  )}
</Base>
