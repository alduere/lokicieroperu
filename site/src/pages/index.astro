---
import Base from "../layouts/Base.astro";
import FilterBar from "../components/FilterBar.astro";
import { latestHubDate, getHubDay, formatFechaEs, getEpDay, getIndecopiDay, getConsumidorDay, getGacetaDay, latestTfDate, getTfDay, latestNoticiasDate, getNoticiasDay } from "../lib/data";
import type { NormaResumida, AlertaResumida, NoticiaResumida, SolicitudPIResumida, ResolucionTFResumida, Impacto, PrensaResumida } from "../lib/types";

const date = latestHubDate();
const hub = date ? getHubDay(date) : null;
const base = import.meta.env.BASE_URL.replace(/\/$/, "");

const epDay = date ? getEpDay(date) : null;
const indecopiDay = date ? getIndecopiDay(date) : null;

const noticiasDate = latestNoticiasDate();
const noticiasDay = noticiasDate ? getNoticiasDay(noticiasDate) : null;
const noticiasItems = noticiasDay ? noticiasDay.noticias : [];
const noticiasTotal = noticiasItems.length;

const impactOrder: Record<Impacto, number> = { alto: 0, medio: 1, bajo: 2 };
const epAllItems = epDay
  ? [...epDay.normas].sort((a, b) => impactOrder[a.impacto] - impactOrder[b.impacto])
  : [];
const epTotal = epDay ? epDay.normas.length : 0;

const epSectorGroups = new Map<string, NormaResumida[]>();
for (const n of epAllItems) {
  const primary = n.sectores[0] || "administracion_publica";
  if (!epSectorGroups.has(primary)) epSectorGroups.set(primary, []);
  epSectorGroups.get(primary)!.push(n);
}
const epSortedSectors = [...epSectorGroups.entries()].sort((a, b) => b[1].length - a[1].length);

const indecopiItems = indecopiDay ? indecopiDay.items : [];
const indecopiTotal = indecopiItems.length;

const consumidorDay = date ? getConsumidorDay(date) : null;
const consumidorItems = consumidorDay ? consumidorDay.items : [];
const consumidorTotal = consumidorItems.length;

const gacetaDay = date ? getGacetaDay(date) : null;
const gacetaItemsAll = gacetaDay ? gacetaDay.items : [];
const gacetaVisible = gacetaItemsAll.slice(0, 10);
const gacetaTotal = gacetaItemsAll.length;

const tfDate = latestTfDate();
const tfDay = tfDate ? getTfDay(tfDate) : null;
const tfItemsAll = tfDay ? tfDay.items : [];
const tfVisible = tfItemsAll.slice(0, 5);
const tfTotal = tfItemsAll.length;
const tfRemaining = tfTotal - tfVisible.length;

const epSource = hub?.sources.find((s) => s.slug === "elperuano");

function impactLabel(impacto: Impacto): string {
  return impacto.charAt(0).toUpperCase() + impacto.slice(1);
}

function categoriaPillClass(cat: string): string {
  const lower = cat.toLowerCase();
  if (lower.includes("econom")) return "bg-amber-500/20 text-amber-400";
  if (lower.includes("finanz")) return "bg-emerald-500/20 text-emerald-400";
  if (lower.includes("politi") || lower.includes("polit")) return "bg-rose-500/20 text-rose-400";
  return "bg-loki-elevated text-txt-muted";
}

const fuentesActivas = noticiasDay ? noticiasDay.fuentes_activas : [];
---

<Base title={hub ? `Loki · ${hub.fecha}` : "Loki"}>
  {hub || noticiasTotal > 0 ? (
    <>
      <section class="text-center py-8 animate-entrance">
        <h1 class="font-display font-extrabold text-4xl sm:text-5xl lg:text-6xl tracking-tightest leading-[0.9] mb-6 text-txt">
          {hub ? formatFechaEs(hub.fecha) : noticiasDate ? formatFechaEs(noticiasDate) : ""}
        </h1>
        {hub && (
          <div class="flex justify-center gap-8 sm:gap-14 text-center animate-entrance delay-2">
            <div>
              <div class="font-display font-extrabold text-4xl sm:text-5xl leading-none text-txt">{hub.stats.total_publicaciones}</div>
              <div class="text-[10px] uppercase tracking-[0.2em] text-txt-dim mt-2 font-sans font-medium">Publicaciones</div>
            </div>
            <div>
              <div class="font-display font-extrabold text-4xl sm:text-5xl leading-none text-impact-alto">{hub.stats.alertas_alto}</div>
              <div class="text-[10px] uppercase tracking-[0.2em] text-txt-dim mt-2 font-sans font-medium">Alto impacto</div>
            </div>
            <div>
              <div class="font-display font-extrabold text-4xl sm:text-5xl leading-none text-txt">{hub.stats.fuentes_activas}</div>
              <div class="text-[10px] uppercase tracking-[0.2em] text-txt-dim mt-2 font-sans font-medium">Fuentes</div>
            </div>
          </div>
        )}
      </section>

      <div class="border-t border-edge my-6 animate-entrance delay-3"></div>

      {/* ═══ NOTICIAS ═══ */}
      <div class="source-block mb-12 animate-entrance delay-4" data-source="noticias">
        <div class="flex items-end justify-between mb-4">
          <h2 class="font-display font-bold text-xl text-txt">Noticias</h2>
          <span class="font-display font-bold text-2xl text-txt-muted">{noticiasTotal}</span>
        </div>
        <p class="text-txt-dim text-sm mb-4">Prensa economica y politica del dia</p>

        {noticiasTotal > 0 ? (
          <>
            <div class="flex flex-wrap gap-2 mb-4" id="noticias-fuente-chips">
              <button class="noticias-fuente-chip text-xs px-3 py-1.5 rounded-lg font-medium transition-all cursor-pointer bg-loki-elevated text-txt border border-edge" data-fuente="all">Todas</button>
              {fuentesActivas.map((fuente: string) => (
                <button class="noticias-fuente-chip text-xs px-3 py-1.5 rounded-lg font-medium transition-all cursor-pointer bg-transparent text-txt-muted border border-edge-light hover:border-edge" data-fuente={fuente}>{fuente}</button>
              ))}
            </div>
            <div>
              {noticiasItems.slice(0, 10).map((item: PrensaResumida) => (
                <a href={item.url} target="_blank" rel="noopener" class="ruled-item block noticias-hub-item" data-fuente={item.fuente}>
                  <div class="flex items-center gap-2 flex-wrap text-[11px] text-txt-dim mb-1">
                    <span class={`inline-flex items-center px-2 py-0.5 rounded-md text-[10px] font-semibold flex-shrink-0 ${categoriaPillClass(item.categoria)}`}>{item.categoria}</span>
                    <span>{item.fuente_display}</span>
                    <span class="text-edge">&middot;</span>
                    <span>{item.fecha}</span>
                  </div>
                  <h3 class="font-display font-bold text-txt leading-snug">{item.titulo}</h3>
                  {item.resumen && <p class="text-sm text-txt-muted mt-1.5 line-clamp-2">{item.resumen}</p>}
                </a>
              ))}
            </div>
            {noticiasTotal > 10 && (
              <a href={`${base}/noticias/`} class="inline-block mt-4 text-sm font-medium text-txt-muted hover:text-txt transition-colors">+ {noticiasTotal - 10} mas &rarr;</a>
            )}
          </>
        ) : (
          <p class="text-txt-dim text-sm py-4">No hay noticias disponibles para hoy.</p>
        )}
      </div>

      {/* ═══ EL PERUANO ═══ */}
      {epSource && epSource.total > 0 && epDay && (
        <div class="source-block mb-12 animate-entrance delay-4 hidden" data-source="elperuano">
          <div class="flex items-end justify-between mb-1">
            <h2 class="font-display font-bold text-xl text-txt">{epSource.nombre}</h2>
            <span class="font-display font-bold text-2xl text-txt-muted" id="filter-count">{epSource.total} normas</span>
          </div>
          <p class="text-txt-dim text-sm mb-1">{epSource.subtitulo}</p>
          <FilterBar normas={epDay.normas} />
          {epSortedSectors.map(([sector, norms]) => (
            <article class="mb-6" data-sector-card>
              <header class="flex items-baseline justify-between gap-3 pb-2 mb-1 border-b border-edge">
                <h3 class="font-display font-bold text-lg capitalize text-txt">
                  {sector.replace(/_/g, " ")}
                  <span class="text-txt-dim font-sans text-sm font-normal ml-2">({norms.length})</span>
                </h3>
              </header>
              <div>
                {norms.map((norma) => (
                  <a href={`${base}/elperuano/n/${norma.id}`} class="ruled-item block" data-norma data-tipo={norma.tipo_corto} data-impacto={norma.impacto} data-sectores={(norma.sectores || []).join(",")}>
                    <div class="flex items-start gap-2 mb-1">
                      <span class={`impact-pill ${norma.impacto} flex-shrink-0`}>{impactLabel(norma.impacto)}</span>
                      <span class="font-display font-bold text-txt leading-snug">{norma.titulo_oficial}</span>
                    </div>
                    <div class="text-xs text-txt-dim ml-0 mt-1">{norma.tipo_corto} · {norma.entidad_emisora}</div>
                    {(norma.impacto === "alto" || norma.impacto === "medio") && norma.resumen_ejecutivo && (
                      <p class="text-sm text-txt-muted mt-1.5 line-clamp-2">{norma.resumen_ejecutivo}</p>
                    )}
                  </a>
                ))}
              </div>
            </article>
          ))}
          <a href={`${base}/elperuano/`} class="inline-block mt-2 text-sm font-medium text-txt-muted hover:text-txt transition-colors">Ver pagina completa &rarr;</a>
        </div>
      )}

      {/* ═══ INDECOPI ═══ */}
      {(indecopiTotal + consumidorTotal + gacetaTotal) > 0 && (
        <div class="source-block mb-12 animate-entrance delay-5 hidden" data-source="indecopi">
          <div class="flex items-end justify-between mb-1">
            <h2 class="font-display font-bold text-xl text-txt">INDECOPI</h2>
            <span class="font-display font-bold text-2xl text-txt-muted">{indecopiTotal + consumidorTotal + gacetaTotal}</span>
          </div>
          <p class="text-txt-dim text-sm mb-4">Alertas, proteccion al consumidor, propiedad industrial</p>

          {indecopiTotal > 0 && (
            <div class="mb-6">
              <div class="flex items-center justify-between mb-2">
                <h3 class="text-xs uppercase tracking-widest text-txt-dim font-medium">Alertas</h3>
                <span class="text-xs text-txt-dim">{indecopiTotal}</span>
              </div>
              {indecopiItems.slice(0, 3).map((item) => (
                <a href={`${base}/indecopi/alertas/item/${item.id}`} class="ruled-item block">
                  <div class="flex items-start gap-2 mb-1">
                    <span class={`impact-pill ${item.impacto} flex-shrink-0`}>{impactLabel(item.impacto)}</span>
                    <span class="font-display font-bold text-txt leading-snug">{item.titulo}</span>
                  </div>
                  <div class="text-xs text-txt-dim ml-0 mt-1">{item.categoria || "Alerta"} &middot; {item.marca || "Sin marca"}</div>
                </a>
              ))}
              {indecopiTotal > 3 && <a href={`${base}/indecopi/alertas/`} class="inline-block mt-2 text-xs font-medium text-txt-muted hover:text-txt transition-colors">+ {indecopiTotal - 3} mas &rarr;</a>}
            </div>
          )}

          {consumidorTotal > 0 && (
            <div class="mb-6">
              <div class="flex items-center justify-between mb-2">
                <h3 class="text-xs uppercase tracking-widest text-txt-dim font-medium">Consumidor</h3>
                <span class="text-xs text-txt-dim">{consumidorTotal}</span>
              </div>
              {consumidorItems.slice(0, 3).map((noticia) => (
                <div class="ruled-item block">
                  <div class="flex items-start gap-2 mb-1">
                    <span class={`impact-pill ${noticia.impacto} flex-shrink-0`}>{impactLabel(noticia.impacto)}</span>
                    <span class="font-display font-bold text-txt leading-snug">{noticia.titulo}</span>
                  </div>
                </div>
              ))}
              {consumidorTotal > 3 && <a href={`${base}/indecopi/consumidor/`} class="inline-block mt-2 text-xs font-medium text-txt-muted hover:text-txt transition-colors">+ {consumidorTotal - 3} mas &rarr;</a>}
            </div>
          )}

          {gacetaTotal > 0 && (
            <div class="mb-6">
              <div class="flex items-center justify-between mb-2">
                <h3 class="text-xs uppercase tracking-widest text-txt-dim font-medium">Gaceta PI</h3>
                <span class="text-xs text-txt-dim">{gacetaTotal}</span>
              </div>
              {gacetaVisible.slice(0, 5).map((item) => (
                <a href={`${base}/indecopi/gaceta-pi/item/${item.id}`} class="ruled-item block">
                  <div class="flex items-start gap-2 mb-1">
                    <span class="text-xs px-2 py-0.5 bg-loki-elevated border border-edge text-txt-muted rounded-md flex-shrink-0">{item.tipo_solicitud}</span>
                    <span class="font-display font-bold text-txt leading-snug">{item.signo_solicitado}</span>
                  </div>
                  <div class="text-xs text-txt-dim ml-0 mt-1">{item.solicitante}{item.clase ? ` · Clase ${item.clase}` : ""}</div>
                </a>
              ))}
              {gacetaTotal > 5 && <a href={`${base}/indecopi/gaceta-pi/`} class="inline-block mt-2 text-xs font-medium text-txt-muted hover:text-txt transition-colors">+ {gacetaTotal - 5} mas &rarr;</a>}
            </div>
          )}
          <a href={`${base}/indecopi/`} class="inline-block mt-2 text-sm font-medium text-txt-muted hover:text-txt transition-colors">+ Ver todo en INDECOPI &rarr;</a>
        </div>
      )}

      {/* ═══ TRIBUNAL FISCAL ═══ */}
      {tfTotal > 0 ? (
        <div class="source-block mb-12 animate-entrance delay-6 hidden" data-source="tribunal-fiscal">
          <div class="flex items-end justify-between mb-1">
            <h2 class="font-display font-bold text-xl text-txt">Tribunal Fiscal</h2>
            <span class="font-display font-bold text-2xl text-txt-muted">{tfTotal}</span>
          </div>
          <p class="text-txt-dim text-sm mb-4">Jurisprudencia tributaria — resoluciones del dia</p>
          {tfVisible.map((item) => (
            <a href={`${base}/tribunal-fiscal/item/${item.id}`} class="ruled-item block">
              <div class="flex items-start gap-2 mb-1">
                <span class={`impact-pill ${item.impacto} flex-shrink-0`}>{impactLabel(item.impacto)}</span>
                <span class="font-display font-bold text-txt leading-snug">{item.numero_rtf}</span>
              </div>
              {item.sumilla && <p class="text-sm text-txt-muted mt-1 line-clamp-2">{item.sumilla}</p>}
              <div class="text-xs text-txt-dim ml-0 mt-1 flex items-center gap-2">
                {item.sala && <span class="px-2 py-0.5 bg-loki-elevated border border-edge text-txt-muted rounded-md">{item.sala}</span>}
                {item.tema_tributario && <span>{item.tema_tributario}</span>}
              </div>
            </a>
          ))}
          {tfRemaining > 0 && <a href={`${base}/tribunal-fiscal/`} class="inline-block mt-4 text-sm font-medium text-txt-muted hover:text-txt transition-colors">+ {tfRemaining} mas &rarr;</a>}
        </div>
      ) : (
        <div class="source-block mb-6 opacity-40 hidden" data-source="tribunal-fiscal">
          <div class="flex items-end justify-between pb-2 border-b border-edge">
            <h2 class="font-display font-bold text-lg text-txt">Tribunal Fiscal</h2>
            <span class="font-display font-bold text-xl text-txt-dim">0</span>
          </div>
          <p class="text-txt-dim text-sm mt-1">Jurisprudencia tributaria — resoluciones del dia</p>
        </div>
      )}

      {hub && hub.sources.filter((s) => s.total === 0).length > 0 && (
        <div class="section-divider"><span>Sin novedades hoy</span></div>
      )}
      {hub && hub.sources.filter((s) => s.total === 0).map((source) => {
        const mapped = source.slug === "indecopi-alertas" || source.slug === "consumidor" || source.slug === "gaceta-pi" ? "indecopi" : source.slug;
        return (
          <div class="source-block mb-6 opacity-40" data-source={mapped}>
            <div class="flex items-end justify-between pb-2 border-b border-edge">
              <h2 class="font-display font-bold text-lg text-txt">{source.nombre}</h2>
              <span class="font-display font-bold text-xl text-txt-dim">0</span>
            </div>
            <p class="text-txt-dim text-sm mt-1">{source.subtitulo}</p>
          </div>
        );
      })}
    </>
  ) : (
    <section class="text-center py-16">
      <h1 class="font-display font-extrabold text-3xl mb-3 text-txt">Sin datos todavia</h1>
      <p class="text-txt-dim font-sans">El primer scraping aun no se ha ejecutado. Vuelve manana despues de las 7:00 AM Lima.</p>
    </section>
  )}
</Base>

<script>
  document.addEventListener("DOMContentLoaded", () => {
    const chips = document.querySelectorAll<HTMLButtonElement>(".noticias-fuente-chip");
    const items = document.querySelectorAll<HTMLElement>(".noticias-hub-item");
    if (chips.length === 0) return;
    chips.forEach((chip) => {
      chip.addEventListener("click", () => {
        const fuente = chip.dataset.fuente;
        chips.forEach((c) => {
          c.classList.remove("bg-loki-elevated", "text-txt", "border-edge");
          c.classList.add("bg-transparent", "text-txt-muted", "border-edge-light");
        });
        chip.classList.remove("bg-transparent", "text-txt-muted", "border-edge-light");
        chip.classList.add("bg-loki-elevated", "text-txt", "border-edge");
        items.forEach((item) => {
          if (fuente === "all" || item.dataset.fuente === fuente) {
            item.classList.remove("hidden");
          } else {
            item.classList.add("hidden");
          }
        });
      });
    });
  });
</script>
