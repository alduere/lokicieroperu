---
import Base from "../layouts/Base.astro";
import { latestHubDate, getHubDay, formatFechaEs, getEpDay, getIndecopiDay, getConsumidorDay, getGacetaDay, latestTfDate, getTfDay, latestNoticiasDate, getNoticiasDay } from "../lib/data";
import type { NormaResumida, AlertaResumida, NoticiaResumida, SolicitudPIResumida, ResolucionTFResumida, Impacto, PrensaResumida } from "../lib/types";

const date = latestHubDate();
const hub = date ? getHubDay(date) : null;
const base = import.meta.env.BASE_URL.replace(/\/$/, "");

// Load source-specific data for item lists
const epDay = date ? getEpDay(date) : null;
const indecopiDay = date ? getIndecopiDay(date) : null;

// Noticias (press news)
const noticiasDate = latestNoticiasDate();
const noticiasDay = noticiasDate ? getNoticiasDay(noticiasDate) : null;
const noticiasItems = noticiasDay ? noticiasDay.noticias : [];
const noticiasTotal = noticiasItems.length;

// El Peruano: sort by impact (alto first), take top 5
const impactOrder: Record<Impacto, number> = { alto: 0, medio: 1, bajo: 2 };
const epItems = epDay
  ? [...epDay.normas]
      .sort((a, b) => impactOrder[a.impacto] - impactOrder[b.impacto])
      .slice(0, 5)
  : [];
const epTotal = epDay ? epDay.normas.length : 0;
const epRemaining = epTotal - epItems.length;

// INDECOPI: show all items
const indecopiItems = indecopiDay ? indecopiDay.items : [];
const indecopiTotal = indecopiItems.length;

// Consumidor: load source data
const consumidorDay = date ? getConsumidorDay(date) : null;
const consumidorItems = consumidorDay ? consumidorDay.items : [];
const consumidorTotal = consumidorItems.length;

// Gaceta PI: load source data, show top 10 on hub
const gacetaDay = date ? getGacetaDay(date) : null;
const gacetaItemsAll = gacetaDay ? gacetaDay.items : [];
const gacetaVisible = gacetaItemsAll.slice(0, 10);
const gacetaTotal = gacetaItemsAll.length;
const gacetaRemaining = gacetaTotal - gacetaVisible.length;

// Tribunal Fiscal: load source data, show top 5 on hub
const tfDate = latestTfDate();
const tfDay = tfDate ? getTfDay(tfDate) : null;
const tfItemsAll = tfDay ? tfDay.items : [];
const tfVisible = tfItemsAll.slice(0, 5);
const tfTotal = tfItemsAll.length;
const tfRemaining = tfTotal - tfVisible.length;

// Hub source metadata
const epSource = hub?.sources.find((s) => s.slug === "elperuano");
const indecopiSource = hub?.sources.find((s) => s.slug === "indecopi-alertas");
const consumidorSource = hub?.sources.find((s) => s.slug === "consumidor");
const gacetaSource = hub?.sources.find((s) => s.slug === "gaceta-pi");

function impactLabel(impacto: Impacto): string {
  return impacto.charAt(0).toUpperCase() + impacto.slice(1);
}

// Category color mapping for noticias (solid background, white text)
function categoriaPillClass(cat: string): string {
  const lower = cat.toLowerCase();
  if (lower.includes("econom")) return "bg-[#9a6b1a] text-white";
  if (lower.includes("finanz")) return "bg-[#3a6b3a] text-white";
  if (lower.includes("politi") || lower.includes("polít")) return "bg-[#8b2020] text-white";
  return "bg-ink-sepia text-white";
}

// Fuentes activas for filter chips
const fuentesActivas = noticiasDay ? noticiasDay.fuentes_activas : [];
---

<Base title={hub ? `Loki-ciero Peru · ${hub.fecha}` : "Loki-ciero Peru"}>
  {hub || noticiasTotal > 0 ? (
    <>
      {/* Hero */}
      <section class="text-center py-8 animate-entrance">
        <div class="text-[10px] uppercase tracking-[0.3em] text-ink-sepia font-sans mb-3 font-semibold">
          Resumen del dia
        </div>
        <h1 class="font-display font-black text-4xl sm:text-5xl lg:text-6xl tracking-tightest leading-[0.9] mb-8">
          {hub ? formatFechaEs(hub.fecha) : noticiasDate ? formatFechaEs(noticiasDate) : ""}
        </h1>
        {hub && (
          <div class="flex justify-center gap-10 sm:gap-16 text-center animate-entrance delay-2">
            <div>
              <div class="font-display font-black text-4xl sm:text-5xl leading-none">{hub.stats.total_publicaciones}</div>
              <div class="text-[10px] uppercase tracking-[0.2em] text-ink-sepia mt-2 font-sans font-semibold">Publicaciones</div>
            </div>
            <div>
              <div class="font-display font-black text-4xl sm:text-5xl leading-none text-impact-alto">{hub.stats.alertas_alto}</div>
              <div class="text-[10px] uppercase tracking-[0.2em] text-ink-sepia mt-2 font-sans font-semibold">Alto impacto</div>
            </div>
            <div>
              <div class="font-display font-black text-4xl sm:text-5xl leading-none">{hub.stats.fuentes_activas}</div>
              <div class="text-[10px] uppercase tracking-[0.2em] text-ink-sepia mt-2 font-sans font-semibold">Fuentes</div>
            </div>
          </div>
        )}
      </section>

      <div class="ornament animate-entrance delay-3"><div class="ornament-diamond"></div></div>

      {/* ═══ NOTICIAS source block (first tab, default visible) ═══ */}
      <div class="source-block mb-12 animate-entrance delay-4" data-source="noticias">
        <div class="border-b-2 border-ink pb-2 mb-1 flex items-end justify-between">
          <div>
            <h2 class="font-display font-black text-2xl tracking-tightest leading-none">
              Noticias
            </h2>
          </div>
          <div class="font-display font-black text-3xl leading-none">
            {noticiasTotal}
          </div>
        </div>
        <div class="font-display italic text-ink-sepia text-sm mb-4">
          Prensa economica y politica del dia
        </div>

        {noticiasTotal > 0 ? (
          <>
            {/* Filter chips */}
            <div class="flex flex-wrap gap-2 mb-4" id="noticias-fuente-chips">
              <button class="noticias-fuente-chip text-xs px-3 py-1.5 rounded-full font-semibold transition-all cursor-pointer bg-ink text-parchment-light" data-fuente="all">
                Todas
              </button>
              {fuentesActivas.map((fuente: string) => (
                <button class="noticias-fuente-chip text-xs px-3 py-1.5 rounded-full font-semibold transition-all cursor-pointer bg-transparent text-ink-sepia border border-ink-rule" data-fuente={fuente}>
                  {fuente}
                </button>
              ))}
            </div>

            <div>
              {noticiasItems.slice(0, 10).map((item: PrensaResumida) => (
                <a
                  href={item.url}
                  target="_blank"
                  rel="noopener"
                  class="ruled-item block noticias-hub-item"
                  data-fuente={item.fuente}
                >
                  <div class="flex items-center gap-2 flex-wrap text-[11px] text-ink-sepia mb-1">
                    <span class={`inline-flex items-center px-2 py-0.5 rounded text-[10px] font-semibold flex-shrink-0 ${categoriaPillClass(item.categoria)}`}>
                      {item.categoria}
                    </span>
                    <span>{item.fuente_display}</span>
                    <span class="text-ink-rule">&middot;</span>
                    <span>{item.fecha}</span>
                  </div>
                  <h3 class="font-display font-bold text-ink leading-snug">
                    {item.titulo}
                  </h3>
                  {item.resumen && (
                    <p class="text-sm text-ink-light mt-1.5 line-clamp-2">
                      {item.resumen}
                    </p>
                  )}
                </a>
              ))}
            </div>

            {noticiasTotal > 10 && (
              <a
                href={`${base}/noticias/`}
                class="inline-block mt-4 text-sm font-semibold text-ink-sepia hover:text-ink transition-colors"
              >
                + {noticiasTotal - 10} mas &rarr;
              </a>
            )}
          </>
        ) : (
          <p class="text-ink-sepia text-sm py-4">No hay noticias disponibles para hoy.</p>
        )}
      </div>

      {/* ═══ El Peruano source block ═══ */}
      {epSource && epSource.total > 0 && (
        <div class="source-block mb-12 animate-entrance delay-4 hidden" data-source="elperuano">
          {/* Source header */}
          <div class="border-b-2 border-ink pb-2 mb-1 flex items-end justify-between">
            <div>
              <h2 class="font-display font-black text-2xl tracking-tightest leading-none">
                {epSource.nombre}
              </h2>
            </div>
            <div class="font-display font-black text-3xl leading-none">
              {epSource.total}
            </div>
          </div>
          <div class="font-display italic text-ink-sepia text-sm mb-3">
            {epSource.subtitulo}
          </div>

          {/* Impact pills */}
          {epSource.categorias.length > 0 && (
            <div class="flex gap-2 mb-4">
              {epSource.categorias.map((cat) => (
                <span class={`impact-pill ${cat.nombre}`}>
                  {impactLabel(cat.nombre as Impacto)} {cat.count}
                </span>
              ))}
            </div>
          )}

          {/* Item list */}
          <div>
            {epItems.map((norma) => (
              <a
                href={`${base}/elperuano/n/${norma.id}`}
                class="ruled-item block"
              >
                <div class="flex items-start gap-2 mb-1">
                  <span class={`impact-pill ${norma.impacto} flex-shrink-0`}>
                    {impactLabel(norma.impacto)}
                  </span>
                  <span class="font-display font-bold text-ink leading-snug">
                    {norma.titulo_oficial}
                  </span>
                </div>
                <div class="text-xs text-ink-sepia ml-0 mt-1">
                  {norma.tipo_corto} · {norma.entidad_emisora}
                </div>
                {(norma.impacto === "alto" || norma.impacto === "medio") && norma.resumen_ejecutivo && (
                  <p class="text-sm text-ink-light mt-1.5 line-clamp-2">
                    {norma.resumen_ejecutivo}
                  </p>
                )}
              </a>
            ))}
          </div>

          {epRemaining > 0 && (
            <a
              href={`${base}/elperuano/`}
              class="inline-block mt-4 text-sm font-semibold text-ink-sepia hover:text-ink transition-colors"
            >
              + {epRemaining} mas &rarr;
            </a>
          )}
        </div>
      )}

      {/* ═══ INDECOPI combined source block ═══ */}
      {(indecopiTotal + consumidorTotal + gacetaTotal) > 0 && (
        <div class="source-block mb-12 animate-entrance delay-5 hidden" data-source="indecopi">
          {/* Source header */}
          <div class="border-b-2 border-ink pb-2 mb-1 flex items-end justify-between">
            <div>
              <h2 class="font-display font-black text-2xl tracking-tightest leading-none">
                INDECOPI
              </h2>
            </div>
            <div class="font-display font-black text-3xl leading-none">
              {indecopiTotal + consumidorTotal + gacetaTotal}
            </div>
          </div>
          <div class="font-display italic text-ink-sepia text-sm mb-3">
            Alertas, proteccion al consumidor, propiedad industrial
          </div>

          {/* Alertas mini-section */}
          {indecopiTotal > 0 && (
            <div class="mb-6">
              <div class="flex items-center justify-between mb-2">
                <h3 class="text-xs uppercase tracking-widest text-ink-sepia font-semibold">Alertas</h3>
                <span class="text-xs text-ink-sepia">{indecopiTotal}</span>
              </div>
              <div>
                {indecopiItems.slice(0, 3).map((item) => (
                  <a
                    href={`${base}/indecopi/alertas/item/${item.id}`}
                    class="ruled-item block"
                  >
                    <div class="flex items-start gap-2 mb-1">
                      <span class={`impact-pill ${item.impacto} flex-shrink-0`}>
                        {impactLabel(item.impacto)}
                      </span>
                      <span class="font-display font-bold text-ink leading-snug">
                        {item.titulo}
                      </span>
                    </div>
                    <div class="text-xs text-ink-sepia ml-0 mt-1">
                      {item.categoria || "Alerta"} &middot; {item.marca || "Sin marca"}
                    </div>
                  </a>
                ))}
              </div>
              {indecopiTotal > 3 && (
                <a href={`${base}/indecopi/alertas/`} class="inline-block mt-2 text-xs font-semibold text-ink-sepia hover:text-ink transition-colors">
                  + {indecopiTotal - 3} mas &rarr;
                </a>
              )}
            </div>
          )}

          {/* Consumidor mini-section */}
          {consumidorTotal > 0 && (
            <div class="mb-6">
              <div class="flex items-center justify-between mb-2">
                <h3 class="text-xs uppercase tracking-widest text-ink-sepia font-semibold">Consumidor</h3>
                <span class="text-xs text-ink-sepia">{consumidorTotal}</span>
              </div>
              <div>
                {consumidorItems.slice(0, 3).map((noticia) => (
                  <div class="ruled-item block">
                    <div class="flex items-start gap-2 mb-1">
                      <span class={`impact-pill ${noticia.impacto} flex-shrink-0`}>
                        {impactLabel(noticia.impacto)}
                      </span>
                      <span class="font-display font-bold text-ink leading-snug">
                        {noticia.titulo}
                      </span>
                    </div>
                  </div>
                ))}
              </div>
              {consumidorTotal > 3 && (
                <a href={`${base}/indecopi/consumidor/`} class="inline-block mt-2 text-xs font-semibold text-ink-sepia hover:text-ink transition-colors">
                  + {consumidorTotal - 3} mas &rarr;
                </a>
              )}
            </div>
          )}

          {/* Gaceta PI mini-section */}
          {gacetaTotal > 0 && (
            <div class="mb-6">
              <div class="flex items-center justify-between mb-2">
                <h3 class="text-xs uppercase tracking-widest text-ink-sepia font-semibold">Gaceta PI</h3>
                <span class="text-xs text-ink-sepia">{gacetaTotal}</span>
              </div>
              <div>
                {gacetaVisible.slice(0, 5).map((item) => (
                  <a
                    href={`${base}/indecopi/gaceta-pi/item/${item.id}`}
                    class="ruled-item block"
                  >
                    <div class="flex items-start gap-2 mb-1">
                      <span class="text-xs px-2 py-0.5 bg-parchment-light border border-ink-rule-light text-ink-light rounded-full flex-shrink-0">
                        {item.tipo_solicitud}
                      </span>
                      <span class="font-display font-bold text-ink leading-snug">
                        {item.signo_solicitado}
                      </span>
                    </div>
                    <div class="text-xs text-ink-sepia ml-0 mt-1">
                      {item.solicitante}{item.clase ? ` &middot; Clase ${item.clase}` : ""}
                    </div>
                  </a>
                ))}
              </div>
              {gacetaTotal > 5 && (
                <a href={`${base}/indecopi/gaceta-pi/`} class="inline-block mt-2 text-xs font-semibold text-ink-sepia hover:text-ink transition-colors">
                  + {gacetaTotal - 5} mas &rarr;
                </a>
              )}
            </div>
          )}

          <a
            href={`${base}/indecopi/`}
            class="inline-block mt-2 text-sm font-semibold text-ink-sepia hover:text-ink transition-colors"
          >
            + Ver todo en INDECOPI &rarr;
          </a>
        </div>
      )}

      {/* ═══ Tribunal Fiscal source block ═══ */}
      {tfTotal > 0 ? (
        <div class="source-block mb-12 animate-entrance delay-6 hidden" data-source="tribunal-fiscal">
          <div class="border-b-2 border-ink pb-2 mb-1 flex items-end justify-between">
            <div>
              <h2 class="font-display font-black text-2xl tracking-tightest leading-none">
                Tribunal Fiscal
              </h2>
            </div>
            <div class="font-display font-black text-3xl leading-none">
              {tfTotal}
            </div>
          </div>
          <div class="font-display italic text-ink-sepia text-sm mb-3">
            Jurisprudencia tributaria — resoluciones del dia
          </div>

          <div>
            {tfVisible.map((item) => (
              <a
                href={`${base}/tribunal-fiscal/item/${item.id}`}
                class="ruled-item block"
              >
                <div class="flex items-start gap-2 mb-1">
                  <span class={`impact-pill ${item.impacto} flex-shrink-0`}>
                    {impactLabel(item.impacto)}
                  </span>
                  <span class="font-display font-bold text-ink leading-snug">
                    {item.numero_rtf}
                  </span>
                </div>
                {item.sumilla && (
                  <p class="text-sm text-ink-light mt-1 line-clamp-2">{item.sumilla}</p>
                )}
                <div class="text-xs text-ink-sepia ml-0 mt-1 flex items-center gap-2">
                  {item.sala && (
                    <span class="px-2 py-0.5 bg-parchment-light border border-ink-rule-light text-ink-light rounded-full">{item.sala}</span>
                  )}
                  {item.tema_tributario && <span>{item.tema_tributario}</span>}
                </div>
              </a>
            ))}
          </div>

          {tfRemaining > 0 && (
            <a
              href={`${base}/tribunal-fiscal/`}
              class="inline-block mt-4 text-sm font-semibold text-ink-sepia hover:text-ink transition-colors"
            >
              + {tfRemaining} mas &rarr;
            </a>
          )}
        </div>
      ) : (
        <div class="source-block mb-6 opacity-50 hidden" data-source="tribunal-fiscal">
          <div class="border-b border-ink-rule pb-2 flex items-end justify-between">
            <h2 class="font-display font-bold text-lg tracking-tightest">Tribunal Fiscal</h2>
            <div class="font-display font-black text-xl leading-none text-ink-sepia">0</div>
          </div>
          <div class="font-display italic text-ink-sepia text-sm mt-1">Jurisprudencia tributaria — resoluciones del dia</div>
        </div>
      )}

      {/* Fallback: sources with zero items */}
      {hub && hub.sources.filter((s) => s.total === 0).length > 0 && (
        <div class="section-divider"><span>Sin novedades hoy</span></div>
      )}
      {hub && hub.sources.filter((s) => s.total === 0).map((source) => {
        const mapped = source.slug === "indecopi-alertas" || source.slug === "consumidor" || source.slug === "gaceta-pi" ? "indecopi" : source.slug;
        return (
          <div class="source-block mb-6 opacity-50" data-source={mapped}>
            <div class="border-b border-ink-rule pb-2 flex items-end justify-between">
              <h2 class="font-display font-bold text-lg tracking-tightest">{source.nombre}</h2>
              <div class="font-display font-black text-xl leading-none text-ink-sepia">0</div>
            </div>
            <div class="font-display italic text-ink-sepia text-sm mt-1">{source.subtitulo}</div>
          </div>
        );
      })}
    </>
  ) : (
    <section class="text-center py-16">
      <h1 class="font-display font-black text-3xl mb-3">Sin datos todavia</h1>
      <p class="text-ink-sepia font-sans">
        El primer scraping aun no se ha ejecutado. Vuelve manana despues de las 7:00 AM Lima.
      </p>
    </section>
  )}
</Base>

<script>
  document.addEventListener("DOMContentLoaded", () => {
    const chips = document.querySelectorAll<HTMLButtonElement>(".noticias-fuente-chip");
    const items = document.querySelectorAll<HTMLElement>(".noticias-hub-item");
    if (chips.length === 0) return;

    chips.forEach((chip) => {
      chip.addEventListener("click", () => {
        const fuente = chip.dataset.fuente;

        // Update chip styles
        chips.forEach((c) => {
          c.classList.remove("bg-ink", "text-parchment-light");
          c.classList.add("bg-transparent", "text-ink-sepia", "border", "border-ink-rule");
        });
        chip.classList.remove("bg-transparent", "text-ink-sepia", "border-ink-rule");
        chip.classList.add("bg-ink", "text-parchment-light");

        // Filter items
        items.forEach((item) => {
          if (fuente === "all" || item.dataset.fuente === fuente) {
            item.classList.remove("hidden");
          } else {
            item.classList.add("hidden");
          }
        });
      });
    });
  });
</script>
