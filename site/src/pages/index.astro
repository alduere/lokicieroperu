---
import Base from "../layouts/Base.astro";
import FilterBar from "../components/FilterBar.astro";
import { latestHubDate, getHubDay, formatFechaEs, getEpDay, getIndecopiDay, getConsumidorDay, getGacetaDay, latestTfDate, getTfDay, latestNoticiasDate, getNoticiasDay } from "../lib/data";
import type { NormaResumida, AlertaResumida, NoticiaResumida, SolicitudPIResumida, ResolucionTFResumida, Impacto, PrensaResumida } from "../lib/types";

const date = latestHubDate();
const hub = date ? getHubDay(date) : null;
const base = import.meta.env.BASE_URL.replace(/\/$/, "");

const epDay = date ? getEpDay(date) : null;
const indecopiDay = date ? getIndecopiDay(date) : null;

const noticiasDate = latestNoticiasDate();
const noticiasDay = noticiasDate ? getNoticiasDay(noticiasDate) : null;
const noticiasItems = noticiasDay ? noticiasDay.noticias : [];
const noticiasTotal = noticiasItems.length;

const impactOrder: Record<Impacto, number> = { alto: 0, medio: 1, bajo: 2 };
const epAllItems = epDay
  ? [...epDay.normas].sort((a, b) => impactOrder[a.impacto] - impactOrder[b.impacto])
  : [];
const epTotal = epDay ? epDay.normas.length : 0;

const epSectorGroups = new Map<string, NormaResumida[]>();
for (const n of epAllItems) {
  const primary = n.sectores[0] || "administracion_publica";
  if (!epSectorGroups.has(primary)) epSectorGroups.set(primary, []);
  epSectorGroups.get(primary)!.push(n);
}
const epSortedSectors = [...epSectorGroups.entries()].sort((a, b) => b[1].length - a[1].length);

const indecopiItems = indecopiDay ? indecopiDay.items : [];
const indecopiTotal = indecopiItems.length;

const consumidorDay = date ? getConsumidorDay(date) : null;
const consumidorItems = consumidorDay ? consumidorDay.items : [];
const consumidorTotal = consumidorItems.length;

const gacetaDay = date ? getGacetaDay(date) : null;
const gacetaItemsAll = gacetaDay ? gacetaDay.items : [];
const gacetaVisible = gacetaItemsAll.slice(0, 10);
const gacetaTotal = gacetaItemsAll.length;

const tfDate = latestTfDate();
const tfDay = tfDate ? getTfDay(tfDate) : null;
const tfItemsAll = tfDay ? tfDay.items : [];
const tfVisible = tfItemsAll.slice(0, 5);
const tfTotal = tfItemsAll.length;
const tfRemaining = tfTotal - tfVisible.length;

const epSource = hub?.sources.find((s) => s.slug === "elperuano");

function impactLabel(impacto: Impacto): string {
  return impacto.charAt(0).toUpperCase() + impacto.slice(1);
}

function categoriaPillClass(cat: string): string {
  const lower = cat.toLowerCase();
  if (lower.includes("econom")) return "bg-amber-500/20 text-amber-400";
  if (lower.includes("finanz")) return "bg-emerald-500/20 text-emerald-400";
  if (lower.includes("politi") || lower.includes("polit")) return "bg-rose-500/20 text-rose-400";
  return "bg-loki-elevated text-txt-secondary";
}

const fuentesActivas = noticiasDay ? noticiasDay.fuentes_activas : [];

// Noticias: compute category counts
const noticiaCategorias = new Map<string, number>();
for (const n of noticiasItems) {
  noticiaCategorias.set(n.categoria, (noticiaCategorias.get(n.categoria) || 0) + 1);
}
const noticiaCategoriasOrdered = [...noticiaCategorias.entries()].sort((a, b) => b[1] - a[1]);

// INDECOPI: compute impact counts across all subsources
const allIndecopiWithImpact = [
  ...indecopiItems.map((i) => i.impacto),
  ...consumidorItems.map((i) => i.impacto),
];
const indecopiImpactCounts = { alto: 0, medio: 0, bajo: 0 };
for (const imp of allIndecopiWithImpact) {
  if (imp in indecopiImpactCounts) indecopiImpactCounts[imp as Impacto]++;
}

// INDECOPI alertas: category counts
const indecopiCategorias = new Map<string, number>();
for (const a of indecopiItems) {
  const cat = a.categoria || "Alerta";
  indecopiCategorias.set(cat, (indecopiCategorias.get(cat) || 0) + 1);
}

// Tribunal Fiscal: impact counts and sala counts
const tfImpactCounts = { alto: 0, medio: 0, bajo: 0 };
const tfSalas = new Map<string, number>();
for (const r of tfItemsAll) {
  if (r.impacto in tfImpactCounts) tfImpactCounts[r.impacto as Impacto]++;
  if (r.sala) tfSalas.set(r.sala, (tfSalas.get(r.sala) || 0) + 1);
}
---

<Base title={hub ? `Loki · ${hub.fecha}` : "Loki"}>
  {hub || noticiasTotal > 0 ? (
    <>
      <section class="text-center py-8 animate-entrance">
        <h1 class="font-display font-extrabold text-4xl sm:text-5xl lg:text-6xl tracking-tightest leading-[0.9] mb-6 text-txt">
          {hub ? formatFechaEs(hub.fecha) : noticiasDate ? formatFechaEs(noticiasDate) : ""}
        </h1>
        {hub && (
          <div class="flex justify-center gap-8 sm:gap-14 text-center animate-entrance delay-2">
            <div>
              <div class="font-display font-extrabold text-4xl sm:text-5xl leading-none text-txt">{hub.stats.total_publicaciones}</div>
              <div class="text-[10px] uppercase tracking-[0.2em] text-txt-tertiary mt-2 font-sans font-medium">Publicaciones</div>
            </div>
            <div>
              <div class="font-display font-extrabold text-4xl sm:text-5xl leading-none text-impact-alto">{hub.stats.alertas_alto}</div>
              <div class="text-[10px] uppercase tracking-[0.2em] text-txt-tertiary mt-2 font-sans font-medium">Alto impacto</div>
            </div>
            <div>
              <div class="font-display font-extrabold text-4xl sm:text-5xl leading-none text-txt">{hub.stats.fuentes_activas}</div>
              <div class="text-[10px] uppercase tracking-[0.2em] text-txt-tertiary mt-2 font-sans font-medium">Fuentes</div>
            </div>
          </div>
        )}
      </section>

      <div class="border-t border-edge my-6 animate-entrance delay-3"></div>

      {/* ═══ NOTICIAS ═══ */}
      <div class="source-block mb-12 animate-entrance delay-4" data-source="noticias">
        <div class="flex items-end justify-between mb-2">
          <h2 class="font-display font-bold text-xl text-txt">Noticias</h2>
          <span class="font-display font-bold text-2xl text-txt-secondary">{noticiasTotal}</span>
        </div>
        <p class="text-txt-tertiary text-sm mb-3">Prensa economica y politica del dia</p>

        {noticiasTotal > 0 && (
          <>
            {/* Category filter chips */}
            <div class="flex flex-wrap gap-1.5 mb-3" id="noticias-cat-chips">
              <button class="noticias-cat-chip text-xs px-3 py-1.5 rounded-lg font-medium transition-all cursor-pointer bg-loki-elevated text-txt border border-edge" data-cat="all">Todas</button>
              {noticiaCategoriasOrdered.map(([cat, count]) => (
                <button class={`noticias-cat-chip text-xs px-3 py-1.5 rounded-lg font-medium transition-all cursor-pointer border border-edge-light hover:border-edge ${categoriaPillClass(cat)}`} data-cat={cat}>
                  {cat} ({count})
                </button>
              ))}
            </div>

            {/* Source filter chips */}
            {fuentesActivas.length > 1 && (
              <div class="flex flex-wrap gap-1.5 mb-4" id="noticias-fuente-chips">
                <button class="noticias-fuente-chip text-xs px-3 py-1.5 rounded-lg font-medium transition-all cursor-pointer bg-loki-elevated text-txt border border-edge" data-fuente="all">Todas fuentes</button>
                {fuentesActivas.map((fuente: string) => (
                  <button class="noticias-fuente-chip text-xs px-3 py-1.5 rounded-lg font-medium transition-all cursor-pointer bg-transparent text-txt-secondary border border-edge-light hover:border-edge" data-fuente={fuente}>{fuente}</button>
                ))}
              </div>
            )}

            <div>
              {noticiasItems.slice(0, 10).map((item: PrensaResumida) => (
                <a href={item.url} target="_blank" rel="noopener" class="ruled-item block noticias-hub-item" data-fuente={item.fuente} data-cat={item.categoria}>
                  <div class="flex items-center gap-2 flex-wrap text-[11px] text-txt-tertiary mb-1">
                    <span class={`inline-flex items-center px-2 py-0.5 rounded-md text-[10px] font-semibold flex-shrink-0 ${categoriaPillClass(item.categoria)}`}>{item.categoria}</span>
                    <span>{item.fuente_display}</span>
                    <span class="text-edge">&middot;</span>
                    <span>{item.fecha}</span>
                  </div>
                  <h3 class="font-display font-bold text-txt leading-snug">{item.titulo}</h3>
                  {item.resumen && <p class="text-sm text-txt-secondary mt-1.5 line-clamp-2">{item.resumen}</p>}
                </a>
              ))}
            </div>
            {noticiasTotal > 10 && (
              <a href={`${base}/noticias/`} class="inline-block mt-4 text-sm font-medium text-txt-secondary hover:text-txt transition-colors">+ {noticiasTotal - 10} mas &rarr;</a>
            )}
          </>
        )}
        {noticiasTotal === 0 && <p class="text-txt-tertiary text-sm py-4">No hay noticias disponibles para hoy.</p>}
      </div>

      {/* ═══ EL PERUANO ═══ */}
      {epSource && epSource.total > 0 && epDay && (
        <div class="source-block mb-12 animate-entrance delay-4 hidden" data-source="elperuano">
          <div class="flex items-end justify-between mb-1">
            <h2 class="font-display font-bold text-xl text-txt">{epSource.nombre}</h2>
            <span class="font-display font-bold text-2xl text-txt-secondary" id="filter-count">{epSource.total} normas</span>
          </div>
          <p class="text-txt-tertiary text-sm mb-1">{epSource.subtitulo}</p>
          <FilterBar normas={epDay.normas} />
          {epSortedSectors.map(([sector, norms]) => (
            <article class="mb-6" data-sector-card>
              <header class="flex items-baseline justify-between gap-3 pb-2 mb-1 border-b border-edge">
                <h3 class="font-display font-bold text-lg capitalize text-txt">
                  {sector.replace(/_/g, " ")}
                  <span class="text-txt-tertiary font-sans text-sm font-normal ml-2">({norms.length})</span>
                </h3>
              </header>
              <div>
                {norms.map((norma) => (
                  <a href={`${base}/elperuano/n/${norma.id}`} class="ruled-item block" data-norma data-tipo={norma.tipo_corto} data-impacto={norma.impacto} data-sectores={(norma.sectores || []).join(",")}>
                    <div class="flex items-start gap-2 mb-1">
                      <span class={`impact-pill ${norma.impacto} flex-shrink-0`}>{impactLabel(norma.impacto)}</span>
                      <span class="font-display font-bold text-txt leading-snug">{norma.titulo_oficial}</span>
                    </div>
                    <div class="text-xs text-txt-tertiary ml-0 mt-1">{norma.tipo_corto} · {norma.entidad_emisora}</div>
                    {(norma.impacto === "alto" || norma.impacto === "medio") && norma.resumen_ejecutivo && (
                      <p class="text-sm text-txt-secondary mt-1.5 line-clamp-2">{norma.resumen_ejecutivo}</p>
                    )}
                  </a>
                ))}
              </div>
            </article>
          ))}
          <a href={`${base}/elperuano/`} class="inline-block mt-2 text-sm font-medium text-txt-secondary hover:text-txt transition-colors">Ver pagina completa &rarr;</a>
        </div>
      )}

      {/* ═══ INDECOPI ═══ */}
      {(indecopiTotal + consumidorTotal + gacetaTotal) > 0 && (
        <div class="source-block mb-12 animate-entrance delay-5 hidden" data-source="indecopi">
          <div class="flex items-end justify-between mb-1">
            <h2 class="font-display font-bold text-xl text-txt">INDECOPI</h2>
            <span class="font-display font-bold text-2xl text-txt-secondary" id="indecopi-count">{indecopiTotal + consumidorTotal + gacetaTotal}</span>
          </div>
          <p class="text-txt-tertiary text-sm mb-3">Alertas, proteccion al consumidor, propiedad industrial</p>

          {/* Impact semaphore */}
          {(indecopiImpactCounts.alto + indecopiImpactCounts.medio + indecopiImpactCounts.bajo) > 0 && (
            <div class="flex flex-wrap gap-1.5 mb-3" id="indecopi-impact-chips">
              <button class="indecopi-impact-chip text-xs px-3 py-1.5 rounded-lg font-medium transition-all cursor-pointer bg-loki-elevated text-txt border border-edge" data-impact="all">Todos</button>
              {indecopiImpactCounts.alto > 0 && (
                <button class="indecopi-impact-chip text-xs px-3 py-1.5 rounded-lg font-medium transition-all cursor-pointer border border-edge-light text-impact-alto hover:bg-loki-elevated" data-impact="alto">Alto ({indecopiImpactCounts.alto})</button>
              )}
              {indecopiImpactCounts.medio > 0 && (
                <button class="indecopi-impact-chip text-xs px-3 py-1.5 rounded-lg font-medium transition-all cursor-pointer border border-edge-light text-impact-medio hover:bg-loki-elevated" data-impact="medio">Medio ({indecopiImpactCounts.medio})</button>
              )}
              {indecopiImpactCounts.bajo > 0 && (
                <button class="indecopi-impact-chip text-xs px-3 py-1.5 rounded-lg font-medium transition-all cursor-pointer border border-edge-light text-impact-bajo hover:bg-loki-elevated" data-impact="bajo">Bajo ({indecopiImpactCounts.bajo})</button>
              )}
            </div>
          )}

          {/* Alertas mini-section */}
          {indecopiTotal > 0 && (
            <div class="mb-6">
              <div class="flex items-center justify-between mb-2">
                <h3 class="text-xs uppercase tracking-widest text-txt-tertiary font-medium">Alertas</h3>
                <span class="text-xs text-txt-tertiary">{indecopiTotal}</span>
              </div>
              {indecopiItems.slice(0, 3).map((item) => (
                <a href={`${base}/indecopi/alertas/item/${item.id}`} class="ruled-item block indecopi-item" data-impact={item.impacto}>
                  <div class="flex items-start gap-2 mb-1">
                    <span class={`impact-pill ${item.impacto} flex-shrink-0`}>{impactLabel(item.impacto)}</span>
                    <span class="font-display font-bold text-txt leading-snug">{item.titulo}</span>
                  </div>
                  <div class="text-xs text-txt-tertiary ml-0 mt-1">{item.categoria || "Alerta"} &middot; {item.marca || "Sin marca"}</div>
                </a>
              ))}
              {indecopiTotal > 3 && <a href={`${base}/indecopi/alertas/`} class="inline-block mt-2 text-xs font-medium text-txt-secondary hover:text-txt transition-colors">+ {indecopiTotal - 3} mas &rarr;</a>}
            </div>
          )}

          {/* Consumidor mini-section */}
          {consumidorTotal > 0 && (
            <div class="mb-6">
              <div class="flex items-center justify-between mb-2">
                <h3 class="text-xs uppercase tracking-widest text-txt-tertiary font-medium">Consumidor</h3>
                <span class="text-xs text-txt-tertiary">{consumidorTotal}</span>
              </div>
              {consumidorItems.slice(0, 3).map((noticia) => (
                <div class="ruled-item block indecopi-item" data-impact={noticia.impacto}>
                  <div class="flex items-start gap-2 mb-1">
                    <span class={`impact-pill ${noticia.impacto} flex-shrink-0`}>{impactLabel(noticia.impacto)}</span>
                    <span class="font-display font-bold text-txt leading-snug">{noticia.titulo}</span>
                  </div>
                </div>
              ))}
              {consumidorTotal > 3 && <a href={`${base}/indecopi/consumidor/`} class="inline-block mt-2 text-xs font-medium text-txt-secondary hover:text-txt transition-colors">+ {consumidorTotal - 3} mas &rarr;</a>}
            </div>
          )}

          {/* Gaceta PI mini-section */}
          {gacetaTotal > 0 && (
            <div class="mb-6">
              <div class="flex items-center justify-between mb-2">
                <h3 class="text-xs uppercase tracking-widest text-txt-tertiary font-medium">Gaceta PI</h3>
                <span class="text-xs text-txt-tertiary">{gacetaTotal}</span>
              </div>
              {gacetaVisible.slice(0, 5).map((item) => (
                <a href={`${base}/indecopi/gaceta-pi/item/${item.id}`} class="ruled-item block">
                  <div class="flex items-start gap-2 mb-1">
                    <span class="text-xs px-2 py-0.5 bg-loki-elevated border border-edge text-txt-secondary rounded-md flex-shrink-0">{item.tipo_solicitud}</span>
                    <span class="font-display font-bold text-txt leading-snug">{item.signo_solicitado}</span>
                  </div>
                  <div class="text-xs text-txt-tertiary ml-0 mt-1">{item.solicitante}{item.clase ? ` · Clase ${item.clase}` : ""}</div>
                </a>
              ))}
              {gacetaTotal > 5 && <a href={`${base}/indecopi/gaceta-pi/`} class="inline-block mt-2 text-xs font-medium text-txt-secondary hover:text-txt transition-colors">+ {gacetaTotal - 5} mas &rarr;</a>}
            </div>
          )}
          <a href={`${base}/indecopi/`} class="inline-block mt-2 text-sm font-medium text-txt-secondary hover:text-txt transition-colors">+ Ver todo en INDECOPI &rarr;</a>
        </div>
      )}

      {/* ═══ TRIBUNAL FISCAL ═══ */}
      {tfTotal > 0 ? (
        <div class="source-block mb-12 animate-entrance delay-6 hidden" data-source="tribunal-fiscal">
          <div class="flex items-end justify-between mb-1">
            <h2 class="font-display font-bold text-xl text-txt">Tribunal Fiscal</h2>
            <span class="font-display font-bold text-2xl text-txt-secondary" id="tf-count">{tfTotal}</span>
          </div>
          <p class="text-txt-tertiary text-sm mb-3">Jurisprudencia tributaria — resoluciones del dia</p>

          {/* Impact semaphore */}
          {(tfImpactCounts.alto + tfImpactCounts.medio + tfImpactCounts.bajo) > 0 && (
            <div class="flex flex-wrap gap-1.5 mb-3" id="tf-impact-chips">
              <button class="tf-impact-chip text-xs px-3 py-1.5 rounded-lg font-medium transition-all cursor-pointer bg-loki-elevated text-txt border border-edge" data-impact="all">Todos</button>
              {tfImpactCounts.alto > 0 && (
                <button class="tf-impact-chip text-xs px-3 py-1.5 rounded-lg font-medium transition-all cursor-pointer border border-edge-light text-impact-alto hover:bg-loki-elevated" data-impact="alto">Alto ({tfImpactCounts.alto})</button>
              )}
              {tfImpactCounts.medio > 0 && (
                <button class="tf-impact-chip text-xs px-3 py-1.5 rounded-lg font-medium transition-all cursor-pointer border border-edge-light text-impact-medio hover:bg-loki-elevated" data-impact="medio">Medio ({tfImpactCounts.medio})</button>
              )}
              {tfImpactCounts.bajo > 0 && (
                <button class="tf-impact-chip text-xs px-3 py-1.5 rounded-lg font-medium transition-all cursor-pointer border border-edge-light text-impact-bajo hover:bg-loki-elevated" data-impact="bajo">Bajo ({tfImpactCounts.bajo})</button>
              )}
            </div>
          )}

          {/* Sala filter */}
          {tfSalas.size > 1 && (
            <div class="flex flex-wrap gap-1.5 mb-4" id="tf-sala-chips">
              <button class="tf-sala-chip text-xs px-3 py-1.5 rounded-lg font-medium transition-all cursor-pointer bg-loki-elevated text-txt border border-edge" data-sala="all">Todas salas</button>
              {[...tfSalas.entries()].sort((a, b) => b[1] - a[1]).map(([sala, count]) => (
                <button class="tf-sala-chip text-xs px-3 py-1.5 rounded-lg font-medium transition-all cursor-pointer bg-transparent text-txt-secondary border border-edge-light hover:border-edge" data-sala={sala}>{sala} ({count})</button>
              ))}
            </div>
          )}

          {tfVisible.map((item) => (
            <a href={`${base}/tribunal-fiscal/item/${item.id}`} class="ruled-item block tf-item" data-impact={item.impacto} data-sala={item.sala || ""}>
              <div class="flex items-start gap-2 mb-1">
                <span class={`impact-pill ${item.impacto} flex-shrink-0`}>{impactLabel(item.impacto)}</span>
                <span class="font-display font-bold text-txt leading-snug">{item.numero_rtf}</span>
              </div>
              {item.sumilla && <p class="text-sm text-txt-secondary mt-1 line-clamp-2">{item.sumilla}</p>}
              <div class="text-xs text-txt-tertiary ml-0 mt-1 flex items-center gap-2">
                {item.sala && <span class="px-2 py-0.5 bg-loki-elevated border border-edge text-txt-secondary rounded-md">{item.sala}</span>}
                {item.tema_tributario && <span>{item.tema_tributario}</span>}
              </div>
            </a>
          ))}
          {tfRemaining > 0 && <a href={`${base}/tribunal-fiscal/`} class="inline-block mt-4 text-sm font-medium text-txt-secondary hover:text-txt transition-colors">+ {tfRemaining} mas &rarr;</a>}
        </div>
      ) : (
        <div class="source-block mb-6 opacity-40 hidden" data-source="tribunal-fiscal">
          <div class="flex items-end justify-between pb-2 border-b border-edge">
            <h2 class="font-display font-bold text-lg text-txt">Tribunal Fiscal</h2>
            <span class="font-display font-bold text-xl text-txt-tertiary">0</span>
          </div>
          <p class="text-txt-tertiary text-sm mt-1">Jurisprudencia tributaria — resoluciones del dia</p>
        </div>
      )}

      {hub && hub.sources.filter((s) => s.total === 0).length > 0 && (
        <div class="section-divider"><span>Sin novedades hoy</span></div>
      )}
      {hub && hub.sources.filter((s) => s.total === 0).map((source) => {
        const mapped = source.slug === "indecopi-alertas" || source.slug === "consumidor" || source.slug === "gaceta-pi" ? "indecopi" : source.slug;
        return (
          <div class="source-block mb-6 opacity-40" data-source={mapped}>
            <div class="flex items-end justify-between pb-2 border-b border-edge">
              <h2 class="font-display font-bold text-lg text-txt">{source.nombre}</h2>
              <span class="font-display font-bold text-xl text-txt-tertiary">0</span>
            </div>
            <p class="text-txt-tertiary text-sm mt-1">{source.subtitulo}</p>
          </div>
        );
      })}
    </>
  ) : (
    <section class="text-center py-16">
      <h1 class="font-display font-extrabold text-3xl mb-3 text-txt">Sin datos todavia</h1>
      <p class="text-txt-tertiary font-sans">El primer scraping aun no se ha ejecutado. Vuelve manana despues de las 7:00 AM Lima.</p>
    </section>
  )}
</Base>

<script>
  document.addEventListener("DOMContentLoaded", () => {
    // ── Chip filter helper ──
    function setupChipFilter(
      chipSelector: string,
      itemSelector: string,
      dataAttr: string,
      activeClass: string[],
      inactiveClass: string[]
    ) {
      const chips = document.querySelectorAll<HTMLButtonElement>(chipSelector);
      const items = document.querySelectorAll<HTMLElement>(itemSelector);
      if (chips.length === 0) return;

      chips.forEach((chip) => {
        chip.addEventListener("click", () => {
          const val = chip.dataset[dataAttr] || chip.getAttribute(`data-${dataAttr.replace(/([A-Z])/g, '-$1').toLowerCase()}`);

          chips.forEach((c) => {
            activeClass.forEach((cls) => c.classList.remove(cls));
            inactiveClass.forEach((cls) => c.classList.add(cls));
          });
          inactiveClass.forEach((cls) => chip.classList.remove(cls));
          activeClass.forEach((cls) => chip.classList.add(cls));

          items.forEach((item) => {
            const itemVal = item.dataset[dataAttr] || item.getAttribute(`data-${dataAttr.replace(/([A-Z])/g, '-$1').toLowerCase()}`);
            if (val === "all" || itemVal === val) {
              item.classList.remove("hidden");
            } else {
              item.classList.add("hidden");
            }
          });
        });
      });
    }

    const active = ["bg-loki-elevated", "text-txt", "border-edge"];
    const inactive = ["bg-transparent", "text-txt-secondary", "border-edge-light"];

    // Noticias: category filter
    setupChipFilter(".noticias-cat-chip", ".noticias-hub-item", "cat", active, inactive);

    // Noticias: fuente filter
    setupChipFilter(".noticias-fuente-chip", ".noticias-hub-item", "fuente", active, inactive);

    // INDECOPI: impact filter
    setupChipFilter(".indecopi-impact-chip", ".indecopi-item", "impact", active, inactive);

    // Tribunal Fiscal: impact filter
    setupChipFilter(".tf-impact-chip", ".tf-item", "impact", active, inactive);

    // Tribunal Fiscal: sala filter
    setupChipFilter(".tf-sala-chip", ".tf-item", "sala", active, inactive);
  });
</script>
