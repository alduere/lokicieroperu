---
import "../styles/global.css";
import { epSortedDates } from "../lib/data";

interface Props {
  title: string;
  description?: string;
  sourceSlug?: string;
  sourceName?: string;
}

const {
  title,
  description = "Inteligencia regulatoria peruana con IA — El Peruano, INDECOPI y más",
  sourceSlug,
  sourceName,
} = Astro.props;
const base = import.meta.env.BASE_URL.replace(/\/$/, "");
const isHub = !sourceSlug;
---

<!doctype html>
<html lang="es">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>{title}</title>
  <meta name="description" content={description} />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link
    href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@700;800;900&family=Source+Sans+3:ital,wght@0,400;0,600;0,700;1,400&display=swap"
    rel="stylesheet"
  />
  <link rel="icon" href="data:image/svg+xml,%3Csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 100 100'%3E%3Ctext y='.9em' font-size='90'%3E📰%3C/text%3E%3C/svg%3E" />
</head>
<body class="min-h-screen font-sans">
  <!-- Header -->
  <header class="sticky top-0 z-50 bg-parchment double-rule-bottom">
    <div class="max-w-5xl mx-auto px-4 sm:px-6 py-4 flex items-center justify-between">
      <a href={`${base}/`} class="flex items-center gap-3 group">
        <div class="w-10 h-10 bg-ink text-parchment-light grid place-items-center font-display font-bold text-lg tracking-tighter group-hover:rotate-3 transition-transform">
          LK
        </div>
        <div>
          <div class="font-display font-black text-xl leading-none tracking-tightest">Loki-ciero Perú</div>
          <div class="text-[10px] text-ink-sepia mt-0.5 uppercase tracking-[0.2em] font-sans">Inteligencia regulatoria</div>
        </div>
      </a>
      <nav class="flex items-center gap-1 text-sm font-sans">
        {isHub ? (
          <>
            <a href={`${base}/`} class="px-3 py-1.5 hover:text-ink-light font-semibold">Inicio</a>
            <a href={`${base}/buscar`} class="px-3 py-1.5 hover:text-ink-light text-ink-sepia">Buscar todo</a>
          </>
        ) : (
          <>
            <a href={`${base}/`} class="px-3 py-1.5 hover:text-ink-light text-ink-sepia">Inicio</a>
            <a href={`${base}/${sourceSlug}/`} class="px-3 py-1.5 hover:text-ink-light font-semibold">{sourceName || "Hoy"}</a>
            <a href={`${base}/${sourceSlug}/buscar`} class="px-3 py-1.5 hover:text-ink-light text-ink-sepia">Buscar</a>
            <a href={`${base}/${sourceSlug}/archivo`} class="px-3 py-1.5 hover:text-ink-light text-ink-sepia">Archivo</a>
          </>
        )}
        <a href="https://github.com/alduere/lokicieroperu" class="px-3 py-1.5 hover:text-ink-light text-ink-sepia hidden sm:block">Repo</a>
      </nav>
    </div>
  </header>

  <!-- Tabs bar (hub pages only) -->
  {isHub && (
    <nav class="bg-ink/[0.03] border-b border-ink-rule">
      <div class="max-w-5xl mx-auto px-4 sm:px-6 flex gap-0 overflow-x-auto">
        <button class="source-tab active" data-source="all">Todas</button>
        <button class="source-tab" data-source="elperuano">El Peruano</button>
        <button class="source-tab" data-source="indecopi">INDECOPI</button>
        <button class="source-tab" data-source="tribunal-fiscal">Tribunal Fiscal</button>
      </div>
    </nav>
  )}

  <!-- Source-specific nav for INDECOPI -->
  {sourceSlug === "indecopi" && (
    <nav class="bg-ink/[0.03] border-b border-ink-rule">
      <div class="max-w-5xl mx-auto px-4 sm:px-6 flex gap-0 overflow-x-auto">
        <a href={`${base}/indecopi/`} class="source-tab">Hoy</a>
        <a href={`${base}/indecopi/alertas/`} class="source-tab">Alertas</a>
        <a href={`${base}/indecopi/consumidor/`} class="source-tab">Consumidor</a>
        <a href={`${base}/indecopi/gaceta-pi/`} class="source-tab">Gaceta PI</a>
      </div>
    </nav>
  )}

  <!-- Source-specific nav for Tribunal Fiscal -->
  {sourceSlug === "tribunal-fiscal" && (
    <nav class="bg-ink/[0.03] border-b border-ink-rule">
      <div class="max-w-5xl mx-auto px-4 sm:px-6 flex gap-0 overflow-x-auto">
        <a href={`${base}/tribunal-fiscal/`} class="source-tab">Hoy</a>
        <a href={`${base}/tribunal-fiscal/buscar`} class="source-tab">Buscar</a>
        <a href={`${base}/tribunal-fiscal/archivo`} class="source-tab">Archivo</a>
      </div>
    </nav>
  )}

  <main class="max-w-5xl mx-auto px-4 sm:px-6 py-8">
    <slot />
  </main>

  <!-- Footer -->
  <footer class="mt-20 double-rule-top">
    <div class="max-w-5xl mx-auto px-4 sm:px-6 py-10 text-sm text-ink-sepia flex items-start justify-between flex-wrap gap-6">
      <div class="flex flex-col gap-2">
        <div class="font-sans font-semibold text-ink uppercase tracking-wider text-xs mb-1">Fuentes</div>
        <a href={`${base}/elperuano/`} class="hover:text-ink transition-colors">El Peruano</a>
        <a href={`${base}/indecopi/`} class="hover:text-ink transition-colors">INDECOPI</a>
        <a href={`${base}/indecopi/alertas/`} class="hover:text-ink transition-colors">Alertas</a>
        <a href={`${base}/indecopi/consumidor/`} class="hover:text-ink transition-colors">Consumidor</a>
        <a href={`${base}/indecopi/gaceta-pi/`} class="hover:text-ink transition-colors">Gaceta PI</a>
        <a href={`${base}/tribunal-fiscal/`} class="hover:text-ink transition-colors">Tribunal Fiscal</a>
      </div>
      <div class="font-display italic text-ink-sepia text-right">
        {epSortedDates.length} día{epSortedDates.length === 1 ? "" : "s"} publicados
      </div>
    </div>
  </footer>

  {isHub && (
    <script>
      document.addEventListener("DOMContentLoaded", () => {
        const tabs = document.querySelectorAll<HTMLButtonElement>(".source-tab");
        const blocks = document.querySelectorAll<HTMLElement>(".source-block");

        tabs.forEach((tab) => {
          tab.addEventListener("click", () => {
            const source = tab.dataset.source;

            tabs.forEach((t) => t.classList.remove("active"));
            tab.classList.add("active");

            blocks.forEach((block) => {
              if (source === "all" || block.dataset.source === source) {
                block.classList.remove("hidden");
              } else {
                block.classList.add("hidden");
              }
            });
          });
        });
      });
    </script>
  )}
</body>
</html>
