---
import "../styles/global.css";
import { epSortedDates } from "../lib/data";

interface Props {
  title: string;
  description?: string;
  sourceSlug?: string;
  sourceName?: string;
}

const {
  title,
  description = "Inteligencia regulatoria peruana con IA — El Peruano, INDECOPI, Tribunal Fiscal",
  sourceSlug,
  sourceName,
} = Astro.props;
const base = import.meta.env.BASE_URL.replace(/\/$/, "");
const isHub = !sourceSlug;
const today = new Date();
const dayNames = ["Domingo", "Lunes", "Martes", "Miércoles", "Jueves", "Viernes", "Sábado"];
const monthNames = ["enero", "febrero", "marzo", "abril", "mayo", "junio", "julio", "agosto", "septiembre", "octubre", "noviembre", "diciembre"];
const todayStr = `${dayNames[today.getDay()]} ${today.getDate()} de ${monthNames[today.getMonth()]} de ${today.getFullYear()}`;
---

<!doctype html>
<html lang="es">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>{title}</title>
  <meta name="description" content={description} />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,700;0,800;0,900;1,400;1,700&family=Source+Sans+3:ital,wght@0,300;0,400;0,600;0,700;1,400&display=swap" rel="stylesheet" />
  <link rel="icon" href="data:image/svg+xml,%3Csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 100 100'%3E%3Ctext y='.9em' font-size='90'%3E📰%3C/text%3E%3C/svg%3E" />
</head>
<body class="min-h-screen font-sans">

  <!-- ═══ MASTHEAD ═══ -->
  <header class="sticky top-0 z-50 bg-parchment/95 backdrop-blur-sm double-rule-bottom">
    <div class="max-w-5xl mx-auto px-4 sm:px-6">
      <!-- Top dateline -->
      <div class="flex items-center justify-between py-1.5 text-[10px] text-ink-sepia tracking-wider border-b border-ink-rule-light">
        <span class="uppercase">{todayStr}</span>
        <a href="https://github.com/alduere/lokicieroperu" class="hover:text-ink transition-colors hidden sm:block">GitHub</a>
      </div>
      <!-- Main masthead -->
      <div class="flex items-center justify-between py-3">
        <a href={`${base}/`} class="flex items-center gap-3 group">
          <div class="w-9 h-9 bg-ink text-parchment-light grid place-items-center font-display font-black text-sm tracking-tighter group-hover:rotate-2 transition-transform duration-300">
            LK
          </div>
          <div>
            <div class="masthead-title">Loki-ciero Perú</div>
            <div class="masthead-subtitle">Inteligencia regulatoria</div>
          </div>
        </a>
        <nav class="flex items-center gap-0.5 text-[13px] font-sans">
          {isHub ? (
            <>
              <a href={`${base}/`} class="px-2.5 py-1 font-semibold text-ink">Inicio</a>
              <span class="text-ink-rule">|</span>
              <a href={`${base}/buscar`} class="px-2.5 py-1 text-ink-sepia hover:text-ink transition-colors">Buscar</a>
            </>
          ) : (
            <>
              <a href={`${base}/`} class="px-2.5 py-1 text-ink-sepia hover:text-ink transition-colors">Inicio</a>
              <span class="text-ink-rule">|</span>
              <a href={`${base}/${sourceSlug}/`} class="px-2.5 py-1 font-semibold text-ink">{sourceName}</a>
              <span class="text-ink-rule">|</span>
              <a href={`${base}/${sourceSlug}/archivo`} class="px-2.5 py-1 text-ink-sepia hover:text-ink transition-colors">Archivo</a>
            </>
          )}
        </nav>
      </div>
    </div>
  </header>

  <!-- ═══ TABS BAR ═══ -->
  {isHub && (
    <nav class="border-b border-ink-rule bg-parchment">
      <div class="max-w-5xl mx-auto px-4 sm:px-6 flex gap-0 overflow-x-auto">
        <button class="source-tab active" data-source="all">Todas</button>
        <button class="source-tab" data-source="elperuano">El Peruano</button>
        <button class="source-tab" data-source="indecopi">INDECOPI</button>
        <button class="source-tab" data-source="tribunal-fiscal">Tribunal Fiscal</button>
      </div>
    </nav>
  )}

  {sourceSlug === "indecopi" && (
    <nav class="border-b border-ink-rule bg-parchment">
      <div class="max-w-5xl mx-auto px-4 sm:px-6 flex gap-0 overflow-x-auto">
        <a href={`${base}/indecopi/`} class="source-tab">Resumen</a>
        <a href={`${base}/indecopi/alertas/`} class="source-tab">Alertas</a>
        <a href={`${base}/indecopi/consumidor/`} class="source-tab">Consumidor</a>
        <a href={`${base}/indecopi/gaceta-pi/`} class="source-tab">Gaceta PI</a>
      </div>
    </nav>
  )}

  {sourceSlug === "tribunal-fiscal" && (
    <nav class="border-b border-ink-rule bg-parchment">
      <div class="max-w-5xl mx-auto px-4 sm:px-6 flex gap-0 overflow-x-auto">
        <a href={`${base}/tribunal-fiscal/`} class="source-tab">Resoluciones</a>
        <a href={`${base}/tribunal-fiscal/archivo`} class="source-tab">Archivo</a>
      </div>
    </nav>
  )}

  {sourceSlug === "elperuano" && (
    <nav class="border-b border-ink-rule bg-parchment">
      <div class="max-w-5xl mx-auto px-4 sm:px-6 flex gap-0 overflow-x-auto">
        <a href={`${base}/elperuano/`} class="source-tab">Hoy</a>
        <a href={`${base}/elperuano/buscar`} class="source-tab">Buscar</a>
        <a href={`${base}/elperuano/archivo`} class="source-tab">Archivo</a>
      </div>
    </nav>
  )}

  <!-- ═══ MAIN ═══ -->
  <main class="max-w-5xl mx-auto px-4 sm:px-6 py-8">
    <slot />
  </main>

  <!-- ═══ FOOTER ═══ -->
  <footer class="mt-16 double-rule-top pt-8">
    <div class="max-w-5xl mx-auto px-4 sm:px-6 pb-10">
      <div class="flex flex-col sm:flex-row items-start justify-between gap-6">
        <!-- Left: Colophon -->
        <div class="max-w-sm">
          <div class="font-display font-black text-lg mb-2">Loki-ciero Perú</div>
          <p class="text-xs text-ink-sepia leading-relaxed">
            Resumen diario automatizado de normas, alertas y resoluciones regulatorias peruanas.
            Fuentes oficiales scrapeadas con IA a las 7:00 AM Lima. Los resúmenes pueden contener
            errores — consulta siempre el texto oficial.
          </p>
        </div>
        <!-- Right: Source links -->
        <div class="flex gap-8 text-xs">
          <div>
            <div class="font-semibold text-ink uppercase tracking-wider text-[10px] mb-2">Fuentes</div>
            <div class="flex flex-col gap-1.5 text-ink-sepia">
              <a href={`${base}/elperuano/`} class="hover:text-ink transition-colors">El Peruano</a>
              <a href={`${base}/indecopi/`} class="hover:text-ink transition-colors">INDECOPI</a>
              <a href={`${base}/tribunal-fiscal/`} class="hover:text-ink transition-colors">Tribunal Fiscal</a>
            </div>
          </div>
          <div>
            <div class="font-semibold text-ink uppercase tracking-wider text-[10px] mb-2">INDECOPI</div>
            <div class="flex flex-col gap-1.5 text-ink-sepia">
              <a href={`${base}/indecopi/alertas/`} class="hover:text-ink transition-colors">Alertas</a>
              <a href={`${base}/indecopi/consumidor/`} class="hover:text-ink transition-colors">Consumidor</a>
              <a href={`${base}/indecopi/gaceta-pi/`} class="hover:text-ink transition-colors">Gaceta PI</a>
            </div>
          </div>
        </div>
      </div>
      <!-- Bottom rule -->
      <div class="mt-8 pt-4 border-t border-ink-rule flex items-center justify-between text-[10px] text-ink-sepia">
        <span>{epSortedDates.length} ediciones publicadas</span>
        <span class="font-display italic">Hecho con IA en Lima, Perú</span>
      </div>
    </div>
  </footer>

  <!-- ═══ TAB FILTERING ═══ -->
  {isHub && (
    <script>
      document.addEventListener("DOMContentLoaded", () => {
        const tabs = document.querySelectorAll<HTMLButtonElement>(".source-tab");
        const blocks = document.querySelectorAll<HTMLElement>(".source-block");
        tabs.forEach((tab) => {
          tab.addEventListener("click", () => {
            const source = tab.dataset.source;
            tabs.forEach((t) => t.classList.remove("active"));
            tab.classList.add("active");
            blocks.forEach((block) => {
              if (source === "all" || block.dataset.source === source) {
                block.classList.remove("hidden");
                block.style.animation = "fadeUp 0.4s cubic-bezier(0.22, 1, 0.36, 1) both";
              } else {
                block.classList.add("hidden");
              }
            });
          });
        });
      });
    </script>
  )}
</body>
</html>
