---
import "../styles/global.css";
import { epSortedDates, latestFinancieroDate, getFinancieroDay } from "../lib/data";

interface Props {
  title: string;
  description?: string;
  sourceSlug?: string;
  sourceName?: string;
}

const {
  title,
  description = "Inteligencia regulatoria peruana con IA — El Peruano, INDECOPI, Tribunal Fiscal",
  sourceSlug,
  sourceName,
} = Astro.props;
const base = import.meta.env.BASE_URL.replace(/\/$/, "");
const isHub = !sourceSlug;
const today = new Date();
const dayNames = ["Domingo", "Lunes", "Martes", "Miercoles", "Jueves", "Viernes", "Sabado"];
const monthNames = ["enero", "febrero", "marzo", "abril", "mayo", "junio", "julio", "agosto", "septiembre", "octubre", "noviembre", "diciembre"];
const todayStr = `${dayNames[today.getDay()]} ${today.getDate()} de ${monthNames[today.getMonth()]} de ${today.getFullYear()}`;

// Financial ticker data
const finDate = latestFinancieroDate();
const finData = finDate ? getFinancieroDay(finDate) : null;
---

<!doctype html>
<html lang="es">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>{title}</title>
  <meta name="description" content={description} />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Bricolage+Grotesque:opsz,wght@12..96,400;12..96,600;12..96,700;12..96,800&family=DM+Sans:ital,opsz,wght@0,9..40,400;0,9..40,500;0,9..40,600;0,9..40,700;1,9..40,400&display=swap" rel="stylesheet" />
  <link rel="icon" href="data:image/svg+xml,%3Csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 100 100'%3E%3Ctext y='.9em' font-size='90'%3E%F0%9F%94%8D%3C/text%3E%3C/svg%3E" />
</head>
<body class="min-h-screen font-sans">

  <header class="sticky top-0 z-50 bg-loki-bg/95 backdrop-blur-md border-b border-edge">
    <div class="max-w-5xl mx-auto px-4 sm:px-6">
      {/* Financial ticker */}
      {finData && (
        <div class="flex items-center gap-3 py-1.5 overflow-x-auto scrollbar-none border-b border-edge-light text-[11px] font-sans tracking-wide">
          <span class="text-txt-dim font-semibold uppercase flex-shrink-0">Mercados</span>
          {finData.usd_pen.valor > 0 && (
            <>
              <span class="text-edge">|</span>
              <span class="flex items-center gap-1 flex-shrink-0">
                <span class="font-medium text-txt">USD/PEN</span>
                <span class="font-mono text-txt-muted">{finData.usd_pen.valor.toFixed(4)}</span>
                <span class={`font-mono ${finData.usd_pen.variacion_pct > 0 ? "text-impact-bajo" : finData.usd_pen.variacion_pct < 0 ? "text-impact-alto" : "text-txt-dim"}`}>
                  {finData.usd_pen.variacion_pct > 0 ? "+" : ""}{finData.usd_pen.variacion_pct.toFixed(2)}%
                </span>
              </span>
            </>
          )}
          {finData.minerales.filter((m) => m.valor > 0).map((m) => (
            <>
              <span class="text-edge">|</span>
              <span class="flex items-center gap-1 flex-shrink-0">
                <span class="font-medium text-txt">{m.simbolo}</span>
                <span class="font-mono text-txt-muted">{m.valor.toFixed(2)}</span>
                <span class={`font-mono ${m.variacion_pct > 0 ? "text-impact-bajo" : m.variacion_pct < 0 ? "text-impact-alto" : "text-txt-dim"}`}>
                  {m.variacion_pct > 0 ? "+" : ""}{m.variacion_pct.toFixed(2)}%
                </span>
              </span>
            </>
          ))}
        </div>
      )}

      {/* Main masthead */}
      <div class="flex items-center justify-between py-3">
        <a href={`${base}/`} class="flex items-center gap-2 group">
          <span class="masthead-title group-hover:text-accent transition-colors duration-200">Loki</span>
        </a>
        <div class="flex items-center gap-3">
          <span class="text-[11px] text-txt-dim hidden sm:block">{todayStr}</span>
          <nav class="flex items-center gap-1 text-[13px] font-sans">
            {isHub ? (
              <>
                <a href={`${base}/buscar`} class="px-2.5 py-1 text-txt-muted hover:text-txt transition-colors rounded-md hover:bg-loki-surface">Buscar</a>
              </>
            ) : (
              <>
                <a href={`${base}/`} class="px-2.5 py-1 text-txt-muted hover:text-txt transition-colors rounded-md hover:bg-loki-surface">Inicio</a>
                <span class="text-edge">/</span>
                <span class="px-2.5 py-1 font-medium text-txt">{sourceName}</span>
              </>
            )}
          </nav>
        </div>
      </div>
    </div>
  </header>

  {/* ═══ TABS BAR ═══ */}
  {isHub && (
    <nav class="bg-loki-bg border-b border-edge">
      <div class="max-w-5xl mx-auto px-4 sm:px-6 flex gap-1.5 py-2 overflow-x-auto">
        <button class="source-tab active" data-source="noticias">Noticias</button>
        <button class="source-tab" data-source="elperuano">El Peruano</button>
        <button class="source-tab" data-source="indecopi">INDECOPI</button>
        <button class="source-tab" data-source="tribunal-fiscal">Tribunal Fiscal</button>
      </div>
    </nav>
  )}

  {sourceSlug === "noticias" && (
    <nav class="bg-loki-bg border-b border-edge">
      <div class="max-w-5xl mx-auto px-4 sm:px-6 flex gap-1.5 py-2 overflow-x-auto">
        <a href={`${base}/noticias/`} class="source-tab">Hoy</a>
        <a href={`${base}/noticias/archivo`} class="source-tab">Archivo</a>
      </div>
    </nav>
  )}

  {sourceSlug === "indecopi" && (
    <nav class="bg-loki-bg border-b border-edge">
      <div class="max-w-5xl mx-auto px-4 sm:px-6 flex gap-1.5 py-2 overflow-x-auto">
        <a href={`${base}/indecopi/`} class="source-tab">Resumen</a>
        <a href={`${base}/indecopi/alertas/`} class="source-tab">Alertas</a>
        <a href={`${base}/indecopi/consumidor/`} class="source-tab">Consumidor</a>
        <a href={`${base}/indecopi/gaceta-pi/`} class="source-tab">Gaceta PI</a>
      </div>
    </nav>
  )}

  {sourceSlug === "tribunal-fiscal" && (
    <nav class="bg-loki-bg border-b border-edge">
      <div class="max-w-5xl mx-auto px-4 sm:px-6 flex gap-1.5 py-2 overflow-x-auto">
        <a href={`${base}/tribunal-fiscal/`} class="source-tab">Resoluciones</a>
        <a href={`${base}/tribunal-fiscal/archivo`} class="source-tab">Archivo</a>
      </div>
    </nav>
  )}

  {sourceSlug === "elperuano" && (
    <nav class="bg-loki-bg border-b border-edge">
      <div class="max-w-5xl mx-auto px-4 sm:px-6 flex gap-1.5 py-2 overflow-x-auto">
        <a href={`${base}/elperuano/`} class="source-tab">Hoy</a>
        <a href={`${base}/elperuano/buscar`} class="source-tab">Buscar</a>
        <a href={`${base}/elperuano/archivo`} class="source-tab">Archivo</a>
      </div>
    </nav>
  )}

  <main class="max-w-5xl mx-auto px-4 sm:px-6 py-8">
    <slot />
  </main>

  <footer class="mt-16 border-t border-edge pt-8">
    <div class="max-w-5xl mx-auto px-4 sm:px-6 pb-10">
      <div class="flex flex-col sm:flex-row items-start justify-between gap-6">
        <div class="max-w-sm">
          <div class="font-display font-bold text-lg mb-2 text-txt">Loki</div>
          <p class="text-xs text-txt-dim leading-relaxed">
            Resumen diario automatizado de normas, alertas y resoluciones regulatorias peruanas.
            Fuentes oficiales scrapeadas con IA a las 7:00 AM Lima. Los resumenes pueden contener
            errores — consulta siempre el texto oficial.
          </p>
        </div>
        <div class="flex gap-8 text-xs">
          <div>
            <div class="font-medium text-txt-muted uppercase tracking-wider text-[10px] mb-2">Fuentes</div>
            <div class="flex flex-col gap-1.5 text-txt-dim">
              <a href={`${base}/noticias/`} class="hover:text-txt transition-colors">Noticias</a>
              <a href={`${base}/elperuano/`} class="hover:text-txt transition-colors">El Peruano</a>
              <a href={`${base}/indecopi/`} class="hover:text-txt transition-colors">INDECOPI</a>
              <a href={`${base}/tribunal-fiscal/`} class="hover:text-txt transition-colors">Tribunal Fiscal</a>
            </div>
          </div>
          <div>
            <div class="font-medium text-txt-muted uppercase tracking-wider text-[10px] mb-2">INDECOPI</div>
            <div class="flex flex-col gap-1.5 text-txt-dim">
              <a href={`${base}/indecopi/alertas/`} class="hover:text-txt transition-colors">Alertas</a>
              <a href={`${base}/indecopi/consumidor/`} class="hover:text-txt transition-colors">Consumidor</a>
              <a href={`${base}/indecopi/gaceta-pi/`} class="hover:text-txt transition-colors">Gaceta PI</a>
            </div>
          </div>
        </div>
      </div>
      <div class="mt-8 pt-4 border-t border-edge flex items-center justify-between text-[10px] text-txt-dim">
        <span>{epSortedDates.length} ediciones publicadas</span>
        <a href="https://github.com/alduere/lokicieroperu" class="hover:text-txt transition-colors">GitHub</a>
      </div>
    </div>
  </footer>

  {/* ═══ TAB FILTERING ═══ */}
  {isHub && (
    <script>
      document.addEventListener("DOMContentLoaded", () => {
        const tabs = document.querySelectorAll<HTMLButtonElement>(".source-tab");
        const blocks = document.querySelectorAll<HTMLElement>(".source-block");
        tabs.forEach((tab) => {
          tab.addEventListener("click", () => {
            const source = tab.dataset.source;
            tabs.forEach((t) => t.classList.remove("active"));
            tab.classList.add("active");
            blocks.forEach((block) => {
              if (block.dataset.source === source) {
                block.classList.remove("hidden");
                block.style.animation = "fadeUp 0.35s cubic-bezier(0.22, 1, 0.36, 1) both";
              } else {
                block.classList.add("hidden");
              }
            });
          });
        });
      });
    </script>
  )}
</body>
</html>
