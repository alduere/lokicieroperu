---
import "../styles/global.css";
import { epSortedDates } from "../lib/data";

interface Props {
  title: string;
  description?: string;
  sourceSlug?: string;
  sourceName?: string;
}

const {
  title,
  description = "Inteligencia regulatoria peruana con IA — El Peruano, INDECOPI y más",
  sourceSlug,
  sourceName,
} = Astro.props;
const base = import.meta.env.BASE_URL.replace(/\/$/, "");
const isHub = !sourceSlug;
---

<!doctype html>
<html lang="es">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>{title}</title>
  <meta name="description" content={description} />
  <link rel="preconnect" href="https://rsms.me/" />
  <link rel="stylesheet" href="https://rsms.me/inter/inter.css" />
  <link rel="icon" href="data:image/svg+xml,%3Csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 100 100'%3E%3Ctext y='.9em' font-size='90'%3E📰%3C/text%3E%3C/svg%3E" />
</head>
<body class="min-h-screen">
  <header class="border-b border-ink-200 bg-white/70 backdrop-blur sticky top-0 z-50">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-4 flex items-center justify-between">
      <a href={`${base}/`} class="flex items-center gap-3 group">
        <div class="w-10 h-10 rounded-xl bg-ink-900 text-white grid place-items-center font-bold text-lg tracking-tighter group-hover:rotate-3 transition-transform">LK</div>
        <div>
          <div class="font-bold text-lg leading-none">Loki-ciero Perú</div>
          <div class="text-xs text-ink-500 mt-0.5 uppercase tracking-wider">Inteligencia regulatoria</div>
        </div>
      </a>
      <nav class="flex items-center gap-1 text-sm">
        {isHub ? (
          <>
            <a href={`${base}/`} class="px-3 py-1.5 rounded-lg hover:bg-ink-100 font-medium">Inicio</a>
            <a href={`${base}/buscar`} class="px-3 py-1.5 rounded-lg hover:bg-ink-100 font-medium">Buscar todo</a>
          </>
        ) : (
          <>
            <a href={`${base}/`} class="px-3 py-1.5 rounded-lg hover:bg-ink-100 text-ink-500">Inicio</a>
            <a href={`${base}/${sourceSlug}/`} class="px-3 py-1.5 rounded-lg hover:bg-ink-100 font-medium">{sourceName || "Hoy"}</a>
            <a href={`${base}/${sourceSlug}/buscar`} class="px-3 py-1.5 rounded-lg hover:bg-ink-100 font-medium">Buscar</a>
            <a href={`${base}/${sourceSlug}/archivo`} class="px-3 py-1.5 rounded-lg hover:bg-ink-100 font-medium">Archivo</a>
          </>
        )}
        <a href="https://github.com/alduere/lokicieroperu" class="px-3 py-1.5 rounded-lg hover:bg-ink-100 font-medium hidden sm:block">Repo</a>
      </nav>
    </div>
  </header>

  <main class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
    <slot />
  </main>

  <footer class="mt-20 border-t border-ink-200 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-10 text-sm text-ink-500">
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        <div>
          <div class="font-semibold text-ink-900 mb-2">Loki-ciero Perú</div>
          <p>Resumen diario automatizado de normas, alertas y resoluciones regulatorias peruanas. Cada día a las 7:00 AM hora Lima.</p>
        </div>
        <div>
          <div class="font-semibold text-ink-900 mb-2">Cómo funciona</div>
          <p>Scrapeamos fuentes oficiales (El Peruano, INDECOPI), resumimos con IA y publicamos en este sitio + Telegram + email. Open-source en GitHub.</p>
        </div>
        <div>
          <div class="font-semibold text-ink-900 mb-2">Aviso</div>
          <p>Los resúmenes son generados por IA y pueden tener errores. Para decisiones legales, consulta siempre el texto oficial de cada fuente.</p>
        </div>
      </div>
      <div class="mt-8 pt-6 border-t border-ink-200 flex items-center justify-between flex-wrap gap-2">
        <div>
          Fuentes: <a href="https://diariooficial.elperuano.pe" class="text-ink-700 hover:text-ink-900 underline">El Peruano</a> ·
          <a href="https://www.indecopi.gob.pe" class="text-ink-700 hover:text-ink-900 underline">INDECOPI</a>
        </div>
        <div>
          {epSortedDates.length} día{epSortedDates.length === 1 ? "" : "s"} publicados
        </div>
      </div>
    </div>
  </footer>
</body>
</html>
